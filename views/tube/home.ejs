<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>わかめtube Plus</title>
    <script src="/js/tailwindcss.js"></script>
    <script src="https://code.jquery.com/jquery-3.5.1.js"></script>
    <style>
        .shorts-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: black; z-index: 1000; }
        .shorts-container { height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; position: relative; }
        .shorts-player-wrapper { width: 100%; height: 100%; max-width: 100%; aspect-ratio: 9/16; background: #000; position: relative; }
        .shorts-iframe { width: 100%; height: 100%; border: none; }
        .shorts-controls { position: absolute; right: 20px; bottom: 100px; display: flex; flex-direction: column; gap: 20px; z-index: 1001; }
        .shorts-btn { background: rgba(255,255,255,0.2); border-radius: 50%; width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; font-size: 24px; cursor: pointer; color: white; }
        .shorts-info { position: absolute; bottom: 20px; left: 20px; right: 80px; z-index: 1001; pointer-events: none; }
    </style>
</head>
<body class="bg-gray-900 text-white">

<header class="p-4 bg-gray-800 flex items-center justify-between sticky top-0 z-50">
    <div class="flex items-center gap-4">
        <h1 class="text-xl font-bold">わかめtube</h1>
        <nav class="flex gap-4">
            <a href="/wkt" class="hover:text-blue-400">ホーム</a>
            <a href="/wkt/trend" class="hover:text-blue-400">トレンド</a>
            <button id="shortsBtn" class="bg-red-600 px-3 py-1 rounded-full font-bold text-sm">Shorts</button>
            <a href="/music" class="hover:text-blue-400">Music</a>
        </nav>
    </div>
    <form action="/wkt/s" method="get" class="w-1/3">
        <input type="text" name="q" placeholder="検索" class="w-full bg-gray-700 p-2 rounded-full px-4 outline-none focus:ring-2 ring-blue-500">
    </form>
</header>

<main class="p-4 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        <% if (results && results.length > 0) { %>
            <% results.forEach(v => { %>
                <a href="/wkt/watch/<%= v.id %>" class="group">
                    <div class="relative aspect-video rounded-xl overflow-hidden shadow-lg">
                        <img src="/wkt/back/vi/<%= v.id %>/mqdefault.jpg" class="w-full h-full object-cover group-hover:scale-105 transition duration-300">
                        <span class="absolute bottom-2 right-2 bg-black bg-opacity-80 text-xs px-2 py-1 rounded"><%= v.duration?.text %></span>
                    </div>
                    <div class="mt-3">
                        <h3 class="font-bold line-clamp-2 group-hover:text-blue-400"><%= v.title?.text %></h3>
                        <p class="text-sm text-gray-400 mt-1"><%= v.author?.name %></p>
                        <p class="text-xs text-gray-500"><%= v.short_view_count?.text %> ・ <%= v.published?.text %></p>
                    </div>
                </a>
            <% }) %>
        <% } %>
    </div>
</main>

<!-- Shorts Player Overlay (Choco方式) -->
<div id="shortsOverlay" class="shorts-overlay">
    <div class="shorts-container">
        <div class="shorts-player-wrapper" id="shortsPlayerWrapper">
            <!-- Iframe will be inserted here -->
        </div>
        <div class="shorts-controls">
            <div id="shortsNext" class="shorts-btn">↓</div>
            <div id="shortsPrev" class="shorts-btn">↑</div>
            <div id="shortsClose" class="shorts-btn">✕</div>
        </div>
        <div class="shorts-info">
            <h3 id="shortsTitle" class="font-bold text-lg drop-shadow-lg"></h3>
            <p id="shortsAuthor" class="text-sm text-gray-300 drop-shadow-lg"></p>
        </div>
    </div>
</div>

<script>
$(document).ready(function() {
    let shortsList = [];
    let currentIndex = -1;

    $('#shortsBtn').click(async function() {
        $('#shortsOverlay').fadeIn();
        if (shortsList.length === 0) {
            await loadShorts();
        }
        if (shortsList.length > 0) playShort(0);
    });

    async function loadShorts() {
        const history = JSON.parse(localStorage.getItem('wakametubeserhistory') || '[]');
        const q = history.length > 0 ? history[history.length-1] : 'Shorts';
        try {
            const res = await fetch(`/wkt/back/search?q=${encodeURIComponent(q)}&type=video`);
            const html = await res.text();
            const temp = document.createElement('div');
            temp.innerHTML = html;
            const links = temp.querySelectorAll('a[href*="/wkt/watch/"]');
            const idSet = new Set();
            links.forEach(link => {
                const idMatch = link.href.match(/\/wkt\/watch\/([a-zA-Z0-9_-]{11})/);
                if (idMatch && !idSet.has(idMatch[1])) {
                    idSet.add(idMatch[1]);
                    shortsList.push({ id: idMatch[1], title: link.innerText.trim() });
                }
            });
        } catch (e) { console.error(e); }
    }

    function playShort(index) {
        if (index < 0 || index >= shortsList.length) return;
        currentIndex = index;
        const item = shortsList[index];
        $('#shortsTitle').text(item.title);
        
        // Choco方式 (YouTube Education Embed / Nocookie)
        const embedUrl = `https://www.youtube-nocookie.com/embed/${item.id}?autoplay=1&loop=1&playlist=${item.id}&controls=0&modestbranding=1&rel=0`;
        $('#shortsPlayerWrapper').html(`<iframe class="shorts-iframe" src="${embedUrl}" allow="autoplay; encrypted-media" allowfullscreen></iframe>`);
    }

    $('#shortsNext').click(() => playShort(currentIndex + 1));
    $('#shortsPrev').click(() => playShort(currentIndex - 1));
    $('#shortsClose').click(() => {
        $('#shortsPlayerWrapper').empty();
        $('#shortsOverlay').fadeOut();
    });

    // キーボード操作
    $(document).keydown(function(e) {
        if (!$('#shortsOverlay').is(':visible')) return;
        if (e.key === "ArrowDown") $('#shortsNext').click();
        else if (e.key === "ArrowUp") $('#shortsPrev').click();
        else if (e.key === "Escape") $('#shortsClose').click();
    });
});
</script>
</body>
</html>
