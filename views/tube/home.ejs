<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ホーム</title>
    <link rel="stylesheet" href="/css/page.css">
    <script src="/js/tailwindcss.js"></script>
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
    <script src="https://code.jquery.com/jquery-3.5.1.js"></script>
    <script src="https://code.jquery.com/ui/1.12.1/jquery-ui.js"></script>
    <script src="/js/tube.js"></script>
    <style>
        .hero-section {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 50vh;
            background-color: #2d3748;
        }
        .searchbox {
            position: absolute;
            transform: translate(-50%, 0%);
            width: 80%;
            max-width: 700px;
            padding: 0.75rem;
            font-size: 1.2rem;
            border-radius: 25px;
            border: none;
            background-color: rgba(255, 255, 255, 0.1);
            color: white;
            outline: none;
            transition: all 0.3s ease;
        }
        .searchbox:focus {
            background-color: rgba(255, 255, 255, 0.3);
            box-shadow: 0 0 8px rgba(255, 255, 255, 0.5);
        }
        .app-card-container {
            display: flex;
            justify-content: center;
            gap: 16px;
            margin-top: 30px;
            flex-wrap: wrap;
        }
        .app-card {
            background-color: #1a202c;
            border-radius: 25px;
            padding: 15px;
            width: 180px;
            text-align: center;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            border: 2px solid #4a5568;
        }
        .app-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 4px 10px rgba(255, 255, 255, 0.1);
        }
        .app-card img {
            width: 100%;
            height: auto;
            border-radius: 10px;
            margin-bottom: 10px;
        }
        .app-card h3 {
            color: white;
            font-size: 1.1rem;
            margin-bottom: 8px;
        }
        .app-card p {
            color: #cbd5e0;
            font-size: 0.875rem;
        }
        footer {
            background-color: #2d3748;
            color: #cbd5e0;
            padding: 1rem;
            text-align: center;
            margin-top: 50px;
        }
        .logo img {
            height: 30px;
            width: auto;
        }
        /* Shorts UI */
        #shortsOverlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: black;
            z-index: 9999;
            flex-direction: column;
            overflow: hidden;
        }
        #shortsOverlay.active { display: flex; }
        .shorts-container {
            flex: 1;
            width: 100%;
            height: 100%;
            position: relative;
        }
        .shorts-video-wrapper {
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            position: absolute;
            top: 0;
            left: 0;
            transition: transform 0.3s ease-out;
        }
        .shorts-video-wrapper video {
            max-width: 100%;
            max-height: 100%;
            width: auto;
            height: auto;
            object-fit: contain;
        }
        .shorts-info {
            position: absolute;
            bottom: 20px;
            left: 20px;
            right: 20px;
            color: white;
            text-shadow: 1px 1px 3px rgba(0,0,0,0.8);
            pointer-events: none;
            z-index: 10002;
        }
        .shorts-controls {
            position: absolute;
            top: 20px;
            right: 20px;
            display: flex;
            flex-direction: column;
            gap: 15px;
            z-index: 10001;
        }
        .shorts-btn {
            background: rgba(255,255,255,0.2);
            border-radius: 50%;
            width: 50px;
            height: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 24px;
            cursor: pointer;
        }
        .shorts-close {
            position: absolute;
            top: 20px;
            left: 20px;
            font-size: 32px;
            color: white;
            cursor: pointer;
            z-index: 10001;
        }
        #shortsLoading {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: white;
            text-align: center;
            z-index: 10003;
        }
    </style>
</head>
<body class="bg-gray-900 font-sans">

    <header class="bg-gray-800 text-white p-4">
        <nav class="flex justify-between items-center">
            <a href="/?r=y" class="logo">
                <img src="https://count.getloli.com/@wkt-plus?name=wkt-plus&theme=original-new&padding=7&offset=0&align=top&scale=0.4&pixelated=1&darkmode=auto">
            </a>
            <div class="space-x-6 flex items-center">
                <!-- Shorts ボタン追加 -->
                <button id="shortsBtn" class="bg-red-600 hover:bg-red-700 px-3 py-1 rounded-full flex items-center gap-1 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd" />
                    </svg>
                    Shorts
                </button>
                <button id="secretModeBtn" class="hover:text-gray-300 flex items-center transition-colors">🤫シークレット</button>
                <button id="openSettings" class="hover:text-gray-300">⚙️再生方法</button>
                <a href="/wkt/trend" class="hover:text-gray-300">トレンド</a>
                <a href="/wkt/cl/history" class="hover:text-gray-300">再生履歴</a>
                <a href="/wkt/cl/fav" class="hover:text-gray-300">お気に入り</a>
                <a href="/blog/b/wkthelp" class="hover:text-gray-300">ヘルプ</a>
            </div>
        </nav>
    </header>
  
    <section class="hero-section">
        <div class="text-center">
            <a href="/blog/b/wkthelp"><h1 class="text-4xl font-bold text-white mb-4">わかめtube Plus</h1></a>
            <p class="text-lg text-gray-400 mb-6">好きな動画を検索してみましょう！</p>
            <form action="/wkt/s" method="get" id="searchForm">
              <input type="text" name="q" id="searchbox" placeholder="キーワード、もしくはYouTube의 URLを入力..." class="searchbox">
            </form>
        </div>
    </section>

    <section class="py-10 px-4 bg-gray-800">

        <div class="app-card-container">
            <div class="app-card">
                <a href="/blog/b/access">
                <img src="https://wsrv.nl/?url=https://kotonohaworks.com/free-icons/wp-content/uploads/kkrn_icon_server_2.png">
                </a>
                <h3>サーバー状況</h3>
                <p>各サーバーの稼働状況を確認できます。</p>
            </div>
            <div class="app-card">
                <a href="/other">
                <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=https://www.youtube.com/&size=256">
                </a>
                <h3>他のYouTubeサイト</h3>
                <p>他の方が作ったYouTubeサイトを搭載。</p>
            </div>
            <div class="app-card">
                <a href="/game">
                <img src="https://wsrv.nl/?url=https://kotonohaworks.com/free-icons/wp-content/uploads/kkrn_icon_game_1.png">
                </a>
                <h3>APP</h3>
                <p>Webゲームをプレイ。</p>
            </div>
            <div class="app-card">
                <a href="/wakams">
                <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=https://soundcloud.com/&size=256">
                </a>
                <h3>Music</h3>
                <p>音楽を聴くためのアプリ</p>
            </div>
            <div class="app-card">
                <a href="/tools">
                <img src="https://wsrv.nl/?url=https://icooon-mono.com/i/icon_10173/icon_101730_256.png">
                </a>
                <h3>プロキシ＆ツール</h3>
                <p>あなたを助けるかもしれない</p>
            </div>
            <div class="app-card">
                <a href="/blog/b/form">
                <img src="https://wsrv.nl/?url=https://kotonohaworks.com/free-icons/wp-content/uploads/kkrn_icon_otoiawase_1.png">
                </a>
                <h3>お問い合わせ</h3>
                <p>サイトの管理者に問い合わせる</p>
            </div>
        </div>

        <div style="height:480px;" class="w-full max-w-3xl mx-auto mt-10">
            <script src="//accaii.com/wktplus/widget.js" async></script>
        </div>

    </section>

    <!-- Shorts オーバーレイ UI -->
    <div id="shortsOverlay">
        <div class="shorts-close" id="shortsClose">×</div>
        <div id="shortsLoading" style="display:none;">動画を読み込み中...</div>
        <div class="shorts-container" id="shortsContainer">
            <!-- 動画がここに動的に追加される -->
        </div>
        <div class="shorts-controls">
            <div class="shorts-btn" id="shortsNext">↓</div>
            <div class="shorts-btn" id="shortsPrev">↑</div>
        </div>
    </div>

<div id="settingsPanel" class="fixed top-0 left-0 w-full bg-white dark:bg-gray-900 shadow-lg p-6 -translate-y-full duration-300">
    <div class="bg-gray-100 dark:bg-gray-800 text-gray-900 dark:text-white max-w-2xl mx-auto bg-white dark:bg-gray-900 p-6 rounded-lg shadow-md">
      <h1 class="text-2xl font-bold mb-4">再生方法の設定</h1>
      <p class="mb-4 text-gray-700 dark:text-gray-300">再生方法を選択してください。詳しくは<a href="/blog/b/wkthelp" style="color: #60a5fa; text-decoration: underline; transition: color 0.3s ease;">ヘルプ</a>をみてね</p>
      
      <form id="settingsForm" class="space-y-4">
        <label class="block p-4 border rounded-lg cursor-pointer dark:border-gray-700">
          <input type="radio" name="playbackMode" value="normal" class="mr-2"> 
          <span class="font-semibold">通常</span>
          <p class="text-sm text-gray-600 dark:text-gray-400">通常の再生方法で、ストリームを取得して再生を行います。</p>
        </label>
        
        <label class="block p-4 border rounded-lg cursor-pointer dark:border-gray-700">
          <input type="radio" name="playbackMode" value="edu" class="mr-2"> 
          <span class="font-semibold">Education</span>
          <p class="text-sm text-gray-600 dark:text-gray-400">YouTubeEducationを埋め込んで再生を行います。</p>
        </label>
        
        <label class="block p-4 border rounded-lg cursor-pointer dark:border-gray-700">
          <input type="radio" name="playbackMode" value="nocookie" class="mr-2"> 
          <span class="font-semibold">Nocookie</span>
          <p class="text-sm text-gray-600 dark:text-gray-400">YouTube-Nocookieを埋め込んで再生を行います。</p>
        </label>
        
        <button type="button" id="saveButton" class="px-6 py-2 bg-blue-500 text-white rounded-md hover:bg-blue-600 dark:bg-blue-700 dark:hover:bg-blue-600 transition-colors">保存</button>
      </form>

      <button id="closeSettings" class="absolute top-4 right-4 text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white text-4xl font-bold w-12 h-12 flex items-center justify-center rounded-full hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors">
        ×
      </button>
    </div>
</div>

<footer>
    <p>
        ♪( ´▽｀)<br>現在のバージョン: <%= version %>
        <% if (isOutdated) { %>
            <span>(更新あり)</span>
        <% } else { %>
            <span>(最新版)</span>
        <% } %>
    </p>
</footer>

<script>
// ==========================================
// 検索ボックスの処理
// ==========================================
document.getElementById("searchForm").addEventListener("submit", function(event) {
    event.preventDefault();
    const query = document.getElementById("searchbox").value.trim();
    const ytRegex = /(?:https?:\/\/)?(?:www\.)?youtu(?:\.be\/|be\.com\/(?:watch\?v=|embed\/|v\/|shorts\/))([\w\-]+)/;
    const match = query.match(ytRegex);
    
    let targetUrl = '';
    if (match) {
        const videoId = match[1];
        showMessage(`YouTubeのURLとして処理されました☑️`);
        targetUrl = `/wkt/watch/${videoId}`;
    } else {
        targetUrl = `/wkt/s?q=${encodeURIComponent(query)}`;
    }

    if (window === window.parent && localStorage.getItem('secretMode') === 'on') {
        const fullUrl = new URL(targetUrl, window.location.origin).href;
        if (typeof openUrlInAboutBlank === 'function') {
            openUrlInAboutBlank(fullUrl, true);
        } else {
            window.location.href = targetUrl;
        }
    } else {
        window.location.href = targetUrl;
    }
});

// ==========================================
// Shorts 機能の実装 (10本ずつのバッチ読み込み)
// ==========================================
(function() {
    let shortsList = [];
    let currentIndex = 0;
    let isLoading = false;
    let searchTerms = [];
    let termIndex = 0;
    const overlay = document.getElementById('shortsOverlay');
    const container = document.getElementById('shortsContainer');
    const loading = document.getElementById('shortsLoading');

    document.getElementById('shortsBtn').addEventListener('click', async () => {
        overlay.classList.add('active');
        if (shortsList.length === 0) {
            initSearchTerms();
            await loadMoreShorts();
        } else {
            playShort(currentIndex);
        }
    });

    document.getElementById('shortsClose').addEventListener('click', () => {
        overlay.classList.remove('active');
        const currentVideo = container.querySelector('video');
        if (currentVideo) currentVideo.pause();
        const currentAudio = container.querySelector('audio');
        if (currentAudio) currentAudio.pause();
    });

    function initSearchTerms() {
        let history = JSON.parse(localStorage.getItem('wakametubeserhistory') || '[]');
        let query = history.length > 0 ? history[history.length - 1] : 'Shorts';
        searchTerms = [query, 'Shorts', 'ショート動画', '面白動画', 'トレンド', '歌ってみた'];
        termIndex = 0;
        shortsList = [];
        currentIndex = 0;
    }

    async function loadMoreShorts() {
        if (isLoading) return;
        isLoading = true;
        loading.style.display = 'block';
        
        try {
            let newVideos = [];
            while (newVideos.length < 10 && termIndex < searchTerms.length) {
                const term = searchTerms[termIndex];
                const res = await fetch(`/wkt/back/search?q=${encodeURIComponent(term)}&type=video`);
                const html = await res.text();
                const parser = new DOMParser();
                const doc = parser.parseFromString(html, 'text/html');
                const items = doc.querySelectorAll('.result-item');
                
                items.forEach(item => {
                    const link = item.querySelector('a');
                    if (link) {
                        const id = link.href.split('/').pop();
                        const title = item.querySelector('.font-bold')?.textContent || '';
                        const author = item.querySelector('.text-gray-400')?.textContent || '';
                        if (!shortsList.find(v => v.id === id) && !newVideos.find(v => v.id === id)) {
                            newVideos.push({ id, title, author });
                        }
                    }
                });
                termIndex++;
            }
            
            if (newVideos.length > 0) {
                const isFirstLoad = shortsList.length === 0;
                shortsList = shortsList.concat(newVideos);
                if (isFirstLoad) playShort(0);
                else showMessage('次の10本を読み込みました');
            } else if (shortsList.length === 0) {
                loading.textContent = '動画が見つかりませんでした。';
            }
        } catch (e) {
            console.error(e);
            if (shortsList.length === 0) loading.textContent = 'エラーが発生しました。';
        } finally {
            isLoading = false;
            loading.style.display = 'none';
        }
    }

    async function playShort(index) {
        if (index < 0 || index >= shortsList.length) return;
        currentIndex = index;
        container.innerHTML = '';
        
        // 残り3本になったら次の10本を読み込む
        if (index >= shortsList.length - 3 && !isLoading && termIndex < searchTerms.length) {
            loadMoreShorts();
        }

        const videoData = shortsList[index];
        const wrapper = document.createElement('div');
        wrapper.className = 'shorts-video-wrapper';
        
        try {
            const res = await fetch(`/wkt/back/next/${videoData.id}`);
            const data = await res.json();
            
            let videoUrl = data.stream_url;
            let audioUrl = data.audioUrl || '';

            if (data.streamUrls) {
                const target = data.streamUrls.find(s => s.resolution && s.resolution.includes('720') && s.container === 'mp4') 
                             || data.streamUrls.find(s => s.resolution && s.resolution.includes('720'))
                             || data.streamUrls[0];
                if (target) videoUrl = target.url;
            }

            wrapper.innerHTML = `
                <video id="shortsVideo" src="${videoUrl}" loop playsinline style="width:100%; height:100%;"></video>
                <audio id="shortsAudio" src="${audioUrl}" loop></audio>
                <div class="shorts-info">
                    <h3 class="font-bold text-xl">${videoData.title}</h3>
                    <p class="text-sm opacity-80">${videoData.author}</p>
                </div>
            `;
            container.appendChild(wrapper);
            
            const video = wrapper.querySelector('#shortsVideo');
            const audio = wrapper.querySelector('#shortsAudio');

            video.onplay = () => { if (audio.src && audio.src !== window.location.href) audio.play(); };
            video.onpause = () => { audio.pause(); };
            video.onseeking = () => { audio.currentTime = video.currentTime; };

            video.play().catch(e => {
                video.muted = true;
                video.play();
                showMessage('タップして音声を再生');
            });
        } catch (e) {
            console.error(e);
            wrapper.innerHTML = '<div class="text-white">再生エラー</div>';
            container.appendChild(wrapper);
        }
    }

    document.getElementById('shortsNext').addEventListener('click', () => {
        if (currentIndex < shortsList.length - 1) playShort(currentIndex + 1);
        else if (!isLoading) showMessage('読み込み中...');
    });
    document.getElementById('shortsPrev').addEventListener('click', () => {
        if (currentIndex > 0) playShort(currentIndex - 1);
    });

    let touchStartY = 0;
    container.addEventListener('touchstart', e => touchStartY = e.touches[0].clientY);
    container.addEventListener('touchend', e => {
        const touchEndY = e.changedTouches[0].clientY;
        const diff = touchStartY - touchEndY;
        if (Math.abs(diff) > 50) {
            if (diff > 0) document.getElementById('shortsNext').click();
            else document.getElementById('shortsPrev').click();
        }
    });
})();

// ==========================================
// 初期ロード時のメッセージ等
// ==========================================
window.addEventListener("load", function() {
    const hometut = localStorage.getItem('homec');
    if (!hometut) {
      showMessage("ようこそ！もし何か知りたい場合<a href='/blog/b/wkthelp' style='color: #60a5fa;'>ヘルプページ</a>を見てみて下さい。");
      localStorage.setItem('homec', 'true');
    } else if(hometut === "true"){
      showMessage("このサイトは誰でも作ることができます！詳しくは<a href='/blog/b/wkthelp' style='color: #60a5fa;'>わかめtube Plusを作ってみる</a>を見てみて下さい！");
      localStorage.setItem('homec', 'ok');
    }
});

function showMessage(text) {
    const alertMessage = document.createElement('div');
    alertMessage.classList.add(
        'fixed', 'top-4', 'right-4', 'bg-gradient-to-r',
        'from-gray-800', 'to-gray-600', 'text-white',
        'p-5', 'rounded-lg', 'shadow-xl', 'opacity-90',
        'z-50', 'transform', 'scale-100', 'transition-all',
        'border-2', 'border-indigo-500', 'cursor-pointer'
    );
    alertMessage.style.transition = 'transform 0.3s ease, opacity 0.3s ease';
    alertMessage.innerHTML = `
        <div class="flex items-center justify-between space-x-4">
            <span class="font-semibold">ℹ︎ ${text}</span>
            <button class="text-white hover:text-gray-300 focus:outline-none text-xl font-bold" aria-label="閉じる">&times;</button>
        </div>
    `;
    document.body.appendChild(alertMessage);
    const closeButton = alertMessage.querySelector('button');
    const autoRemoveTimer = setTimeout(() => {
        hideMessage(alertMessage);
    }, 3500);
    closeButton.addEventListener('click', () => {
        clearTimeout(autoRemoveTimer);
        hideMessage(alertMessage);
    });
}
function hideMessage(elem) {
    elem.style.transition = 'transform 0.3s ease, opacity 0.3s ease';
    elem.style.opacity = '0';
    elem.style.transform = 'translateX(100%) scale(1.1)';
    setTimeout(() => elem.remove(), 300);
}
  
// ==========================================
// 設定パネル関連
// ==========================================
document.getElementById('openSettings').addEventListener('click', () => {
    document.getElementById('settingsPanel').classList.remove('-translate-y-full');
});
    
document.getElementById('closeSettings').addEventListener('click', () => {
    document.getElementById('settingsPanel').classList.add('-translate-y-full');
});
    
document.getElementById('saveButton').addEventListener('click', () => {
    const mode = document.querySelector('input[name=playbackMode]:checked').value;
    document.cookie = `playbackMode=${mode}; path=/; max-age=31536000`;
    document.getElementById('settingsPanel').classList.add('-translate-y-full');
    showMessage(`再生方法を${mode}に変更しました☑️`);
});
    
window.addEventListener('DOMContentLoaded', () => {
    const cookies = document.cookie.split('; ').reduce((acc, cookie) => {
        const [key, value] = cookie.split('=');
        acc[key] = value;
        return acc;
    }, {});
    const playbackMode = cookies.playbackMode || 'normal';
    const radio = document.querySelector(`input[name=playbackMode][value=${playbackMode}]`);
    if (radio) radio.checked = true;
});


// ==========================================
// シークレットモード
// ==========================================

const secretModeBtn = document.getElementById('secretModeBtn');

if (localStorage.getItem('secretMode') === null) {
    localStorage.setItem('secretMode', 'on');
}

function updateSecretBtnDisplay() {
    const mode = localStorage.getItem('secretMode');
    if (mode === 'on') {
        secretModeBtn.innerHTML = '🤫シークレット <span class="text-green-400 font-bold ml-1 text-sm">(ON)</span>';
    } else {
        secretModeBtn.innerHTML = '🤫シークレット <span class="text-gray-500 font-bold ml-1 text-sm">(OFF)</span>';
    }
}
updateSecretBtnDisplay();

secretModeBtn.addEventListener('click', (e) => {
    e.preventDefault();
    const currentMode = localStorage.getItem('secretMode');
    
    if (currentMode === 'on') {
        if (confirm('シークレットモードをオフにすると履歴が残ってしまいますが、よろしいですか？')) {
            localStorage.setItem('secretMode', 'off');
            updateSecretBtnDisplay();
            showMessage('シークレットモードをOFFにしました。');
        }
    } else {
        localStorage.setItem('secretMode', 'on');
        updateSecretBtnDisplay();
        showMessage('シークレットモードをONにしました。');
    }
});

if (window === window.parent) {
    document.addEventListener('click', function(e) {
        const link = e.target.closest('a');
        if (link && link.href && !link.getAttribute('href').startsWith('#') && !link.href.startsWith('javascript:')) {
            if (localStorage.getItem('secretMode') === 'on') {
                e.preventDefault();
                if (typeof openUrlInAboutBlank === 'function') {
                    openUrlInAboutBlank(link.href, true);
                } else {
                    window.location.href = link.href;
                }
            }
        }
    });
}

</script>
</body>
</html>
