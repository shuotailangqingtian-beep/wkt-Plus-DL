<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ホーム</title>
    <link rel="stylesheet" href="/css/page.css">
    <script src="/js/tailwindcss.js"></script>
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
    <script src="https://code.jquery.com/jquery-3.5.1.js"></script>
    <script src="https://code.jquery.com/ui/1.12.1/jquery-ui.js"></script>
    <script src="/js/tube.js"></script>
    <style>
        .hero-section { display: flex; justify-content: center; align-items: center; height: 50vh; background-color: #2d3748; }
        .searchbox { position: absolute; transform: translate(-50%, 0%); width: 80%; max-width: 700px; padding: 0.75rem; font-size: 1.2rem; border-radius: 25px; border: none; background-color: rgba(255, 255, 255, 0.1); color: white; outline: none; transition: all 0.3s ease; }
        .searchbox:focus { background-color: rgba(255, 255, 255, 0.3); box-shadow: 0 0 8px rgba(255, 255, 255, 0.5); }
        .app-card-container { display: flex; justify-content: center; gap: 16px; margin-top: 30px; flex-wrap: wrap; }
        .app-card { background-color: #1a202c; border-radius: 25px; padding: 15px; width: 180px; text-align: center; transition: transform 0.3s ease, box-shadow 0.3s ease; border: 2px solid #4a5568; }
        .app-card:hover { transform: translateY(-10px); box-shadow: 0 4px 10px rgba(255, 255, 255, 0.1); }
        .app-card img { width: 100%; height: auto; border-radius: 10px; margin-bottom: 10px; }
        .app-card h3 { color: white; font-size: 1.1rem; margin-bottom: 8px; }
        .app-card p { color: #cbd5e0; font-size: 0.875rem; }
        footer { background-color: #2d3748; color: #cbd5e0; padding: 1rem; text-align: center; margin-top: 50px; }
        .logo img { height: 30px; width: auto; }
        /* Shorts UI (追加) */
        #shortsOverlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: black; z-index: 9999; flex-direction: column; overflow: hidden; }
        #shortsOverlay.active { display: flex; }
        .shorts-container { flex: 1; position: relative; }
        .shorts-video-wrapper { width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; }
        .shorts-video-wrapper video, .shorts-video-wrapper iframe { max-width: 100%; max-height: 100%; width: 100%; height: 100%; border: none; }
        .shorts-close { position: absolute; top: 20px; left: 20px; font-size: 32px; color: white; cursor: pointer; z-index: 10001; }
        .shorts-controls { position: absolute; top: 50%; right: 20px; transform: translateY(-50%); display: flex; flex-direction: column; gap: 20px; z-index: 10001; }
        .shorts-btn { background: rgba(255,255,255,0.2); width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; cursor: pointer; font-size: 24px; }
        .shorts-info { position: absolute; bottom: 20px; left: 20px; right: 80px; color: white; z-index: 10001; text-shadow: 0 2px 4px rgba(0,0,0,0.8); }
        .shorts-title { font-weight: bold; font-size: 1.1rem; margin-bottom: 4px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
        .shorts-author { font-size: 0.9rem; opacity: 0.9; }
    </style>
</head>
<body class="bg-gray-900 font-sans">
    <header class="bg-gray-800 text-white p-4">
        <nav class="flex justify-between items-center">
            <a href="/?r=y" class="logo">
                <img src="https://count.getloli.com/@wkt-plus?name=wkt-plus&theme=original-new&padding=7&offset=0&align=top&scale=0.4&pixelated=1&darkmode=auto">
            </a>
            <div class="space-x-6 flex items-center">
                <button id="shortsBtn" class="bg-red-600 hover:bg-red-700 px-3 py-1 rounded-full flex items-center gap-1 transition-colors">
                    Shorts
                </button>
                <button id="secretModeBtn" class="hover:text-gray-300 flex items-center transition-colors">🤫シークレット</button>
                <button id="openSettings" class="hover:text-gray-300">⚙️再生方法</button>
                <a href="/wkt/trend" class="hover:text-gray-300">トレンド</a>
                <a href="/wkt/cl/history" class="hover:text-gray-300">再生履歴</a>
                <a href="/wkt/cl/fav" class="hover:text-gray-300">お気に入り</a>
                <a href="/blog/b/wkthelp" class="hover:text-gray-300">ヘルプ</a>
            </div>
        </nav>
    </header>
  
    <section class="hero-section">
        <div class="text-center">
            <a href="/blog/b/wkthelp"><h1 class="text-4xl font-bold text-white mb-4">わかめtube Plus</h1></a>
            <h2 class="text-lg text-gray-400 mb-6">好きな動画を検索してみましょう！</h2>
            <form action="/wkt/s" method="get" id="searchForm">
              <input type="text" name="q" id="searchbox" placeholder="キーワード、もしくはYouTubeのURLを入力..." class="searchbox">
            </form>
        </div>
    </section>

    <section class="py-10 px-4 bg-gray-800">
        <div class="app-card-container">
            <div class="app-card"><a href="/blog/b/access"><img src="https://wsrv.nl/?url=https://kotonohaworks.com/free-icons/wp-content/uploads/kkrn_icon_server_2.png"></a><h3>サーバー状況</h3><p>各サーバーの稼働状況を確認できます。</p></div>
            <div class="app-card"><a href="/other"><img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=https://www.youtube.com/&size=256"></a><h3>他のYouTubeサイト</h3><p>他の方が作ったYouTubeサイトを搭載。</p></div>
            <div class="app-card"><a href="/game"><img src="https://wsrv.nl/?url=https://kotonohaworks.com/free-icons/wp-content/uploads/kkrn_icon_game_1.png"></a><h3>APP</h3><p>Webゲームをプレイ。</p></div>
            <div class="app-card"><a href="/wakams"><img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=https://soundcloud.com/&size=256"></a><h3>Music</h3><p>音楽を聴くためのアプリ</p></div>
            <div class="app-card"><a href="/tools"><img src="https://wsrv.nl/?url=https://icooon-mono.com/i/icon_10173/icon_101730_256.png"></a><h3>プロキシ＆ツール</h3><p>あなたを助けるかもしれない</p></div>
            <div class="app-card"><a href="/blog/b/form"><img src="https://wsrv.nl/?url=https://kotonohaworks.com/free-icons/wp-content/uploads/kkrn_icon_otoiawase_1.png"></a><h3>お問い合わせ</h3><p>サイトの管理者に問い合わせる</p></div>
        </div>
        <div style="height:480px;" class="w-full max-w-3xl mx-auto mt-10">
            <script src="//accaii.com/wktplus/widget.js" async></script>
        </div>
    </section>

    <div id="settingsPanel" class="fixed top-0 left-0 w-full bg-white dark:bg-gray-900 shadow-lg p-6 -translate-y-full duration-300 z-[10002]">
        <div class="bg-gray-100 dark:bg-gray-800 text-gray-900 dark:text-white max-w-2xl mx-auto p-6 rounded-lg shadow-md">
          <h1 class="text-2xl font-bold mb-4">再生方法の設定</h1>
          <form id="settingsForm" class="space-y-4">
            <label class="block p-4 border rounded-lg cursor-pointer"><input type="radio" name="playbackMode" value="normal" class="mr-2"> <span class="font-semibold">通常 (ストリーム)</span></label>
            <label class="block p-4 border rounded-lg cursor-pointer"><input type="radio" name="playbackMode" value="edu" class="mr-2"> <span class="font-semibold">Education (Choco方式)</span></label>
            <label class="block p-4 border rounded-lg cursor-pointer"><input type="radio" name="playbackMode" value="nocookie" class="mr-2"> <span class="font-semibold">Nocookie (埋め込み)</span></label>
            <button type="button" id="saveButton" class="px-6 py-2 bg-blue-500 text-white rounded-md hover:bg-blue-600">保存</button>
          </form>
          <button id="closeSettings" class="absolute top-4 right-4 text-4xl font-bold">×</button>
        </div>
    </div>

    <div id="shortsOverlay">
        <div class="shorts-close" id="shortsClose">×</div>
        <div class="shorts-container" id="shortsContainer"></div>
        <div class="shorts-info" id="shortsInfo"></div>
        <div class="shorts-controls"><div class="shorts-btn" id="shortsNext">↓</div><div class="shorts-btn" id="shortsPrev">↑</div></div>
    </div>

    <footer><p>♪( ´▽｀)<br>現在のバージョン: <%= version %> (<%= isOutdated ? '更新あり' : '最新版' %>)</p></footer>

<script>
// ==========================================
// オリジナルの検索ロジック (維持)
// ==========================================
document.getElementById("searchForm").addEventListener("submit", function(e) {
    e.preventDefault();
    const q = document.getElementById("searchbox").value.trim();
    const ytRegex = /(?:https?:\/\/)?(?:www\.)?youtu(?:\.be\/|be\.com\/(?:watch\?v=|embed\/|v\/|shorts\/))([\w\-]+)/;
    const m = q.match(ytRegex);
    if (m) window.location.href = `/wkt/watch/${m[1]}`;
    else window.location.href = `/wkt/s?q=${encodeURIComponent(q)}`;
});

// ==========================================
// Shorts 機能 (ChocoTube-Plus 方式導入)
// ==========================================
(function() {
    let shorts = []; let current = 0; let loading = false;
    const overlay = document.getElementById('shortsOverlay');
    const container = document.getElementById('shortsContainer');
    const info = document.getElementById('shortsInfo');

    function getPlaybackMode() {
        const m = document.cookie.match(/playbackMode=([^;]+)/);
        return m ? m[1] : 'normal';
    }

    document.getElementById('shortsBtn').onclick = () => { overlay.classList.add('active'); if (shorts.length === 0) loadMore(); else play(current); };
    document.getElementById('shortsClose').onclick = () => { overlay.classList.remove('active'); container.innerHTML = ''; };

    async function loadMore() {
        if (loading) return; loading = true;
        try {
            const h = JSON.parse(localStorage.getItem('wakametubeserhistory') || '[]');
            const q = h.length > 0 ? h[h.length - 1] : 'Shorts';
            const res = await fetch(`/wkt/back/search?q=${encodeURIComponent(q)}&type=video`);
            const html = await res.text();
            
            const idSet = new Set();
            const regex = /\/wkt\/watch\/([a-zA-Z0-9_-]{11})/g;
            let match;
            while ((match = regex.exec(html)) !== null) { idSet.add(match[1]); }
            
            if (idSet.size > 0) {
                const newIds = Array.from(idSet).filter(id => !shorts.find(v => v.id === id));
                newIds.slice(0, 5).forEach(id => shorts.push({ id }));
                if (current === 0 && shorts.length > 0 && !container.querySelector('video, iframe')) play(0);
            }
        } catch (e) { console.error(e); } finally { loading = false; }
    }

    async function play(idx) {
        if (idx < 0 || idx >= shorts.length) return; current = idx;
        container.innerHTML = '<div class="text-white text-center mt-20">読み込み中...</div>';
        info.innerHTML = '';
        if (idx >= shorts.length - 2) loadMore();
        
        const videoId = shorts[idx].id;
        const mode = getPlaybackMode();

        try {
            // メタデータ取得
            const infoRes = await fetch(`/wkt/back/info/${videoId}`);
            const meta = await infoRes.json();
            info.innerHTML = `<div class="shorts-title">${meta.title || ''}</div><div class="shorts-author">${meta.author || ''}</div>`;

            if (mode === 'edu' || mode === 'nocookie') {
                // Choco方式 (Iframe)
                const embedUrl = mode === 'edu' 
                    ? `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1&modestbranding=1&rel=0`
                    : `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1`;
                container.innerHTML = `<div class="shorts-video-wrapper"><iframe src="${embedUrl}" allow="autoplay; encrypted-media" allowfullscreen></iframe></div>`;
            } else {
                // 通常方式 (Stream)
                const res = await fetch(`/wkt/back/next/${videoId}`);
                const data = await res.json();
                let vUrl = data.stream_url; let aUrl = data.audioUrl || '';
                if (data.streamUrls) { 
                    const t = data.streamUrls.find(s => s.resolution?.includes('720') && s.container === 'mp4') || data.streamUrls[0]; 
                    if (t) vUrl = t.url; 
                }
                container.innerHTML = `<div class="shorts-video-wrapper"><video id="sv" src="${vUrl}" loop playsinline controls style="width:100%;height:100%"></video><audio id="sa" src="${aUrl}" loop></audio></div>`;
                const v = document.getElementById('sv'); const a = document.getElementById('sa');
                v.onplay = () => { if (a.src && a.src !== window.location.href) a.play(); };
                v.onpause = () => a.pause();
                v.onseeking = () => a.currentTime = v.currentTime;
                v.play().catch(() => { v.muted = true; v.play(); });
            }
        } catch (e) { container.innerHTML = '<div class="text-white text-center mt-20">エラーが発生しました</div>'; }
    }
    document.getElementById('shortsNext').onclick = () => play(current + 1);
    document.getElementById('shortsPrev').onclick = () => play(current - 1);
})();

// ==========================================
// 設定パネル (維持・拡張)
// ==========================================
(function() {
    const panel = document.getElementById('settingsPanel');
    const form = document.getElementById('settingsForm');
    
    function updateSelected() {
        const m = document.cookie.match(/playbackMode=([^;]+)/);
        const mode = m ? m[1] : 'normal';
        const radio = form.querySelector(`input[value="${mode}"]`);
        if (radio) radio.checked = true;
    }

    document.getElementById('openSettings').onclick = () => { updateSelected(); panel.classList.remove('-translate-y-full'); };
    document.getElementById('closeSettings').onclick = () => panel.classList.add('-translate-y-full');
    document.getElementById('saveButton').onclick = () => {
        const mode = form.querySelector('input[name=playbackMode]:checked').value;
        document.cookie = `playbackMode=${mode}; path=/; max-age=31536000`;
        panel.classList.add('-translate-y-full');
        alert('設定を保存しました。');
    };
})();
</script>
</body>
</html>
