<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= videoInfo.title %></title>
    <link rel="stylesheet" href="/css/page.css">
    <script src="/js/tailwindcss.js"></script>
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
    <script src="https://code.jquery.com/jquery-3.5.1.js"></script>
    <script src="https://code.jquery.com/ui/1.12.1/jquery-ui.js"></script>
    <script src="/js/tube.js"></script>
    <script src="/js/watch.js"></script>
    <link rel="apple-touch-icon" href="/wkt/back/vi/<%= videoId %>/maxresdefault.jpg">
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const isMobile = window.matchMedia("(max-width: 768px)").matches;
            if (isMobile || localStorage.getItem("sidebarHidden") === "true") {
                document.getElementById("sidebar").classList.add("hidden");
                document.getElementById("videoContainer").classList.add("full");
                document.getElementById("expandSidebar").classList.add("visible");
                document.getElementById("related-sidenone").classList.add("hidden");
            }
        });
    </script>
    <style>
        .comment-box, .related-box { transform: translateX(100%); transition: transform 0.2s ease-in-out; }
        .comment-box.open, .related-box.open { transform: translateX(0); }
        .main-container { display: flex; gap: 1rem; align-items: flex-start; transition: width 0.2s ease-in-out; }
        .video-container { flex: 1 1 0; min-width: 0; width: auto; transition: width 0.2s ease-in-out; position: relative; padding-top: 56.25%; background: black; }
        .video-container video, .video-container iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none; }
        .sidebar { flex: 0 0 18rem; width: 18rem; transition: transform 0.2s ease-in-out; }
        .sidebar.hidden { transform: translateX(100%); }
        .expand-sidebar-btn { position: fixed; bottom: 20px; right: 10px; background: #444; color: white; padding: 10px 15px; border-radius: 5px; cursor: pointer; display: none; }
        .expand-sidebar-btn.visible { display: block; }
        .toolbar { position: fixed; top: 0; right: -50%; width: 50%; background: rgba(51, 51, 51, 0.95); transition: right 0.2s; padding: 20px; z-index: 10; }
        .toolbar.open { right: 0; }
        .controlPanel { display: none; }
        .controlPanel.open { display: block; }
        #downloadPanel { display: none; margin-top: 15px; padding: 15px; background: #2d3748; border-radius: 8px; border: 1px solid #4a5568; }
        #downloadPanel.active { display: block; }
    </style>
</head>
<body class="bg-gray-900 text-white">
    <header class="bg-gray-800 p-4 flex justify-between items-center">
        <form action="/wkt/s" method="get" class="w-1/2 relative" id="searchForm">
            <input type="text" name="q" id="searchbox" placeholder="検索" class="searchbox w-full p-2 pr-10 rounded bg-gray-700 text-white">
            <button type="button" id="clearBtn" class="absolute right-2 top-1/2 -translate-y-1/2 text-white hidden">×</button>
        </form>
        <button id="toggleToolbar" class="toggle-btn w-1/5 bg-gray-700 p-2 rounded">ツール</button>
    </header>
  
    <div class="toolbar w-1/2 ml-4" id="toolbar">
        <button id="closeToolbar" class="toggle-btn w-2/3 bg-gray-700 py-2 hover:text-white p-2 rounded mb-2 absolute top-4 right-4">閉じる</button>
        <nav class="mt-12">
            <button onclick="window.location.href='/wkt'" class="w-full bg-gray-700 py-2 hover:text-white p-2 rounded mb-2">ホーム</button>
            <button onclick="window.location.href='/wkt/trend'" class="w-full bg-gray-700 py-2 hover:text-white rounded mb-2">トレンド</button>
        </nav>
    </div>
    
    <div class="max-w-6xl mx-auto p-4 main-container" id="mainContainer">
        <div class="video-container" id="videoContainer">
            <!-- JSで動的に挿入 -->
        </div>

        <div class="flex-1">
            <div class="mt-4 p-4 bg-gray-800 rounded">
                <h1 class="text-2xl font-bold"><%= videoInfo.title %></h1>
                <div class="mt-2 text-gray-400 text-sm">
                    <p><%= videoInfo.viewCount %> ・ <%= videoInfo.published %></p>
                </div>
            </div>

            <!-- コントロールパネル -->
            <div class="mt-4 p-4 bg-gray-800 rounded flex flex-wrap gap-4">
                <div class="flex items-center gap-2">
                    <label>再生方法:</label>
                    <select id="playbackMode" class="bg-gray-700 p-1 rounded">
                        <option value="normal">通常 (Stream)</option>
                        <option value="edu">Education (Choco)</option>
                        <option value="nocookie">Nocookie</option>
                    </select>
                </div>
                <div class="flex items-center gap-2">
                    <label>画質:</label>
                    <select id="qualitySelect" class="bg-gray-700 p-1 rounded">
                        <!-- JSで挿入 -->
                    </select>
                </div>
                <button id="downloadBtn" class="bg-blue-600 px-4 py-1 rounded">ダウンロード</button>
            </div>

            <div id="downloadPanel">
                <h3 class="font-bold mb-2">ダウンロード</h3>
                <div class="flex gap-2">
                    <select id="dlType" class="bg-gray-700 p-2 rounded flex-1">
                        <option value="both">動画 + 音声</option>
                        <option value="video">動画のみ</option>
                        <option value="audio">音声のみ</option>
                    </select>
                    <button id="startDl" class="bg-green-600 px-4 rounded">開始</button>
                </div>
            </div>

            <div class="mt-4 p-4 bg-gray-800 rounded">
                <h3 class="font-bold">概要</h3>
                <div class="description mt-2 text-gray-300 whitespace-pre-wrap"><%- (videoInfo.description || "") %></div>
            </div>
        </div>

        <aside class="sidebar w-80 hidden lg:block" id="sidebar">
            <h3 class="font-bold mb-4">関連動画</h3>
            <% videoInfo.watch_next_feed.forEach(v => { %>
                <% if (v.type.endsWith("Video")) { %>
                    <a href="/wkt/watch/<%= v.id %>" class="flex gap-2 mb-4 group">
                        <img src="/wkt/back/vi/<%= v.id %>/mqdefault.jpg" class="w-32 h-20 object-cover rounded">
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-bold truncate group-hover:text-blue-400"><%= v.title?.text %></p>
                            <p class="text-xs text-gray-400"><%= v.short_view_count?.text %></p>
                        </div>
                    </a>
                <% } %>
            <% }) %>
        </aside>
    </div>

<script>
$(document).ready(function() {
    const videoData = <%- JSON.stringify(videoData) %>;
    const videoId = "<%= videoId %>";
    const container = $('#videoContainer');

    function getMode() {
        const m = document.cookie.match(/playbackMode=([^;]+)/);
        return m ? m[1] : 'normal';
    }

    function initPlayer() {
        const mode = $('#playbackMode').val() || getMode();
        $('#playbackMode').val(mode);

        if (mode === 'edu' || mode === 'nocookie') {
            const embedUrl = mode === 'edu' 
                ? `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1&modestbranding=1&rel=0`
                : `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1`;
            container.html(`<iframe src="${embedUrl}" allow="autoplay; encrypted-media" allowfullscreen></iframe>`);
        } else {
            const streamUrl = videoData.stream_url;
            container.html(`<video id="video" src="${streamUrl}" controls autoplay playsinline style="width:100%;height:100%"></video><audio id="audio" src="${videoData.audioUrl || ''}"></audio>`);
            setupSync();
        }
    }

    function setupSync() {
        const v = document.getElementById('video');
        const a = document.getElementById('audio');
        if (!v || !a) return;
        v.onplay = () => { if (a.src && a.src !== window.location.href) a.play(); };
        v.onpause = () => a.pause();
        v.onseeking = () => a.currentTime = v.currentTime;
        v.play().catch(() => {
            container.append('<div id="playBtn" class="absolute inset-0 flex items-center justify-center bg-black bg-opacity-50 cursor-pointer">再生</div>');
            $('#playBtn').click(function() { v.play(); if (a.src) a.play(); $(this).remove(); });
        });
    }

    $('#playbackMode').change(function() {
        document.cookie = `playbackMode=${$(this).val()}; path=/; max-age=31536000`;
        initPlayer();
    });

    $('#downloadBtn').click(() => $('#downloadPanel').toggle());

    $('#startDl').click(function() {
        const type = $('#dlType').val();
        if (type === 'audio') window.open(videoData.audioUrl, '_blank');
        else window.open(videoData.stream_url, '_blank');
    });

    // 画質ラベル
    if (videoData.streamUrls) {
        videoData.streamUrls.forEach(s => {
            let label = s.resolution;
            if (label.includes('2160')) label = '4K - ' + label;
            if (label.includes('4320')) label = '8K - ' + label;
            $('#qualitySelect').append(`<option value="${s.url}">${label}</option>`);
        });
    }

    initPlayer();
});
</script>
</body>
</html>
