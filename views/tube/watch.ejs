<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= videoInfo.title %> - わかめtube</title>
    <link rel="stylesheet" href="/css/page.css">
    <script src="/js/tailwindcss.js"></script>
    <script src="https://code.jquery.com/jquery-3.5.1.js"></script>
    <script src="/js/tube.js"></script>
    <style>
        .hidden { display: none; }
        #downloadOptions {
            background: rgba(31, 41, 55, 0.95);
            border: 1px solid #4b5563;
            padding: 1rem;
            border-radius: 0.5rem;
            margin-top: 1rem;
            color: white;
        }
    </style>
</head>
<body class="bg-gray-900 text-white">
    <header class="bg-gray-800 p-4 flex justify-between items-center">
        <a href="/wkt" class="text-2xl font-bold">わかめtube</a>
        <div class="flex gap-4">
            <a href="/wkt/trend" class="hover:text-blue-400">トレンド</a>
            <a href="/wkt/cl/history" class="hover:text-blue-400">履歴</a>
        </div>
    </header>

    <main class="max-w-6xl mx-auto p-4 flex flex-col md:flex-row gap-6">
        <div class="flex-1">
            <div id="playerContainer" class="aspect-video bg-black rounded-lg overflow-hidden relative">
                <video id="videoPlayer" class="w-full h-full" controls playsinline></video>
                <audio id="audioPlayer" class="hidden"></audio>
            </div>

            <div class="mt-4">
                <h1 class="text-xl font-bold"><%= videoInfo.title %></h1>
                <div class="flex justify-between items-center mt-2">
                    <p class="text-gray-400"><%= videoInfo.channelName %></p>
                    <div class="flex gap-2">
                        <button id="favoriteBtn" class="bg-gray-700 px-4 py-2 rounded hover:bg-gray-600 flex items-center gap-2">
                            <img id="favoriteIcon" src="" class="w-5 h-5"> お気に入り
                        </button>
                    </div>
                </div>
            </div>

            <div class="mt-6 p-4 bg-gray-800 rounded-lg description">
                <p class="whitespace-pre-wrap"><%= videoInfo.description %></p>
            </div>

            <!-- ダウンロードセクション追加 -->
            <div id="downloadSection" class="mt-4">
                <button id="downloadBtn" class="w-full bg-blue-600 hover:bg-blue-700 py-3 rounded-lg font-bold transition-colors">
                    📥 動画をダウンロード
                </button>
                <div id="downloadOptions" class="hidden">
                    <div class="grid grid-cols-2 gap-4 mb-4">
                        <div>
                            <label class="block text-sm mb-1">タイプ</label>
                            <select id="dlType" class="w-full bg-gray-700 border border-gray-600 rounded p-2">
                                <option value="both">動画 + 音声 (統合版)</option>
                                <option value="video">映像のみ</option>
                                <option value="audio">音声のみ</option>
                                <option value="image">サムネイル</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm mb-1">品質</label>
                            <select id="dlQuality" class="w-full bg-gray-700 border border-gray-600 rounded p-2"></select>
                        </div>
                    </div>
                    <div class="flex gap-2">
                        <button id="dlStart" class="flex-1 bg-green-600 hover:bg-green-700 py-2 rounded font-bold">開始</button>
                        <button id="dlCancel" class="px-4 bg-gray-600 hover:bg-gray-500 py-2 rounded">閉じる</button>
                    </div>
                    <p class="text-xs text-gray-400 mt-2">※ 統合版が表示されない場合は、映像と音声を個別にダウンロードしてください。</p>
                </div>
            </div>

            <div class="mt-8">
                <h2 class="text-lg font-bold mb-4">コメント</h2>
                <div id="comments" class="space-y-4">
                    <% comments.forEach(comment => { %>
                        <div class="flex gap-3">
                            <img src="<%= comment.authorThumb %>" class="w-10 h-10 rounded-full">
                            <div>
                                <p class="font-bold text-sm"><%= comment.author %></p>
                                <p class="text-sm mt-1"><%= comment.text %></p>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>

        <div class="w-full md:w-80 space-y-4">
            <div id="controlPanel" class="bg-gray-800 p-4 rounded-lg">
                <div class="flex border-b border-gray-700 mb-4">
                    <button class="flex-1 py-2 font-bold border-b-2 border-blue-500">設定</button>
                    <button class="flex-1 py-2 text-gray-400">サーバー</button>
                </div>
                
                <div id="settingsTab" class="space-y-4">
                    <div>
                        <label class="block text-sm mb-1">画質選択</label>
                        <select id="qualitySelect" class="w-full bg-gray-700 border border-gray-600 rounded p-2">
                            <option value="<%= videoData.stream_url %>">自動 (標準)</option>
                            <% if (videoData.streamUrls) { %>
                                <% videoData.streamUrls.forEach(s => { %>
                                    <option value="<%= s.url %>" data-is-auto="false"><%= s.resolution %> (<%= s.container %>)</option>
                                <% }) %>
                            <% } %>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm mb-1">音声選択</label>
                        <select id="audioSelect" class="w-full bg-gray-700 border border-gray-600 rounded p-2">
                            <% if (videoData.audioUrls) { %>
                                <% videoData.audioUrls.forEach(a => { %>
                                    <option value="<%= a.url %>"><%= a.label || '標準音声' %></option>
                                <% }) %>
                            <% } else { %>
                                <option value="<%= videoData.audioUrl %>">標準音声</option>
                            <% } %>
                        </select>
                    </div>

                    <!-- 再生モード追加 -->
                    <div class="pt-2 border-t border-gray-700">
                        <label class="block text-sm mb-2">再生モード</label>
                        <div class="flex flex-col gap-2">
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="radio" name="playMode" value="both" checked> 動画 + 音声
                            </label>
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="radio" name="playMode" value="videoOnly"> 映像のみ (ミュート)
                            </label>
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="radio" name="playMode" value="audioOnly"> 音声のみ (映像非表示)
                            </label>
                        </div>
                    </div>

                    <div class="flex gap-2 mt-4">
                        <button id="qualityReset" class="flex-1 bg-gray-700 py-2 rounded text-sm">リセット</button>
                        <button id="saveSettings" class="flex-1 bg-blue-600 py-2 rounded text-sm">保存</button>
                    </div>
                </div>

                <div id="serverTab" class="hidden space-y-4">
                    <select id="serverSelect" class="w-full bg-gray-700 border border-gray-600 rounded p-2">
                        <option value="1">サーバー 1</option>
                        <option value="2">サーバー 2</option>
                    </select>
                    <button id="changeServer" class="w-full bg-blue-600 py-2 rounded">サーバー切り替え</button>
                </div>
            </div>

            <div class="bg-gray-800 p-4 rounded-lg">
                <h3 class="font-bold mb-4">関連動画</h3>
                <div class="space-y-4">
                    <% relatedVideos.forEach(v => { %>
                        <a href="/wkt/watch/<%= v.id %>" class="flex gap-2 group">
                            <img src="<%= v.thumbnail %>" class="w-24 h-16 object-cover rounded">
                            <div class="flex-1">
                                <p class="text-xs font-bold line-clamp-2 group-hover:text-blue-400"><%= v.title %></p>
                                <p class="text-[10px] text-gray-400 mt-1"><%= v.author %></p>
                            </div>
                        </a>
                    <% }) %>
                </div>
            </div>
        </div>
    </main>

    <script>
    $(document).ready(function() {
        const video = document.getElementById('videoPlayer');
        const audio = document.getElementById('audioPlayer');
        const videoSrc = document.createElement('source');
        video.appendChild(videoSrc);

        // 初期設定
        videoSrc.src = "<%= videoData.stream_url %>";
        audio.src = "<%= videoData.audioUrl || '' %>";
        video.load();
        if (audio.src && audio.src !== window.location.href) audio.load();

        // 同期再生ロジック
        video.onplay = () => {
            if (audio.src && audio.src !== window.location.href && !video.muted) audio.play();
        };
        video.onpause = () => audio.pause();
        video.onseeking = () => { audio.currentTime = video.currentTime; };
        video.onvolumechange = () => { audio.volume = video.volume; audio.muted = video.muted; };

        // 外部遷移時（about:blank等）の音声対策
        // ユーザーの最初のクリックでオーディオコンテキストを有効化
        $(document).one('click', () => {
            if (audio.paused && !video.paused) audio.play().catch(e => console.log("Audio play blocked"));
        });

        $('#qualitySelect').change(function() {
            const val = $(this).val();
            const currentTime = video.currentTime;
            videoSrc.src = val;
            video.load();
            video.currentTime = currentTime;
            video.play().catch(e => console.error(e));
        });

        $('#audioSelect').change(function() {
            const val = $(this).val();
            const currentTime = video.currentTime;
            audio.src = val;
            audio.load();
            audio.currentTime = currentTime;
            if (!video.paused) audio.play();
        });

        // 再生モード切り替え
        $('input[name="playMode"]').on('change', function() {
            const mode = $(this).val();
            if (mode === 'both') {
                video.style.display = '';
                video.muted = false;
                if (!video.paused) audio.play();
            } else if (mode === 'videoOnly') {
                video.style.display = '';
                video.muted = false;
                audio.pause();
            } else if (mode === 'audioOnly') {
                video.style.display = 'none';
                if (!video.paused) audio.play();
            }
        });

        // 4K/8K ラベル
        $('#qualitySelect option').each(function() {
            const txt = $(this).text();
            if (txt.includes('4320')) $(this).text('8K - ' + txt);
            else if (txt.includes('2160')) $(this).text('4K - ' + txt);
        });

        // ダウンロード機能
        const videoDataDL = <%- JSON.stringify(videoData) %>;
        $('#downloadBtn').on('click', () => $('#downloadOptions').toggleClass('hidden'));
        $('#dlCancel').on('click', () => $('#downloadOptions').addClass('hidden'));
        $('#dlType').on('change', updateDownloadQualities);

        function updateDownloadQualities() {
            const type = $('#dlType').val();
            const $select = $('#dlQuality');
            $select.empty();
            
            function resLabel(res) {
                if (!res) return res;
                if (res.includes('4320')) return '8K (4320p)';
                if (res.includes('2160')) return '4K (2160p)';
                return res;
            }

            if (type === 'both') {
                // 統合MP4を優先
                if (videoDataDL.streamUrls) {
                    const combined = videoDataDL.streamUrls.filter(s => s.container === 'mp4' && !s.url.includes('manifest'));
                    combined.forEach(s => $select.append(`<option value="${s.url}">${resLabel(s.resolution)} (統合MP4)</option>`));
                }
                if (videoDataDL.stream_url) $select.append(`<option value="${videoDataDL.stream_url}">標準画質 (統合MP4)</option>`);
            } else if (type === 'video') {
                if (videoDataDL.streamUrls) {
                    videoDataDL.streamUrls.forEach(s => $select.append(`<option value="${s.url}">${resLabel(s.resolution)} (${s.container})</option>`));
                }
            } else if (type === 'audio') {
                if (videoDataDL.audioUrls) {
                    videoDataDL.audioUrls.forEach(a => $select.append(`<option value="${a.url}">${a.label || '音声'}</option>`));
                } else if (videoDataDL.audioUrl) {
                    $select.append(`<option value="${videoDataDL.audioUrl}">標準音声</option>`);
                }
            } else if (type === 'image') {
                $select.append(`<option value="/wkt/back/vi/<%= videoId %>/maxresdefault.jpg">最大画質</option>`);
                $select.append(`<option value="/wkt/back/vi/<%= videoId %>/hqdefault.jpg">標準画質</option>`);
            }
            if ($select.children().length === 0) $select.append('<option value="">なし</option>');
        }
        updateDownloadQualities();

        $('#dlStart').on('click', function() {
            const url = $('#dlQuality').val();
            if (url && confirm('ダウンロードを開始しますか？\n(別タブで開きます)')) {
                window.open(url, '_blank');
            }
        });

        // お気に入り
        const videoId = "<%= videoId %>";
        function checkFav() {
            const favs = JSON.parse(localStorage.getItem('wakametubefavorites') || '[]');
            const isFav = favs.some(v => v.videoId === videoId);
            $('#favoriteIcon').attr('src', isFav ? 'https://wsrv.nl/?url=https://kotonohaworks.com/free-icons/wp-content/uploads/kkrn_icon_hoshi_1.png' : 'https://wsrv.nl/?url=https://kotonohaworks.com/free-icons/wp-content/uploads/kkrn_icon_hoshi_4.png');
        }
        checkFav();

        $('#favoriteBtn').click(function() {
            let favs = JSON.parse(localStorage.getItem('wakametubefavorites') || '[]');
            const idx = favs.findIndex(v => v.videoId === videoId);
            if (idx > -1) {
                favs.splice(idx, 1);
                showMessage('お気に入りを解除しました');
            } else {
                favs.push({ videoId, title: "<%= videoInfo.title %>" });
                showMessage('お気に入りに追加しました');
            }
            localStorage.setItem('wakametubefavorites', JSON.stringify(favs));
            checkFav();
        });

        function showMessage(text) {
            const msg = $('<div class="fixed top-4 right-4 bg-blue-600 text-white p-4 rounded shadow-lg z-50"></div>').text(text);
            $('body').append(msg);
            setTimeout(() => msg.fadeOut(() => msg.remove()), 3000);
        }
    });
    </script>
</body>
</html>
