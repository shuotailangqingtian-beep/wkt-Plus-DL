<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= videoInfo.title %></title>
    <link rel="stylesheet" href="/css/page.css">
    <script src="/js/tailwindcss.js"></script>
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
    <script src="https://code.jquery.com/jquery-3.5.1.js"></script>
    <script src="https://code.jquery.com/ui/1.12.1/jquery-ui.js"></script>
    <script src="/js/tube.js"></script>
    <script src="/js/watch.js"></script>
    <link rel="apple-touch-icon" href="/wkt/back/vi/<%= videoId %>/maxresdefault.jpg">
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const isMobile = window.matchMedia("(max-width: 768px)").matches;

            if (isMobile || localStorage.getItem("sidebarHidden") === "true") {
                document.getElementById("sidebar").classList.add("hidden");
                document.getElementById("videoContainer").classList.add("full");
                document.getElementById("expandSidebar").classList.add("visible");
                document.getElementById("related-sidenone").classList.add("hidden");
            }
        });
    </script>
    <style>
        .comment-box, .related-box {
            transform: translateX(100%);
            transition: transform 0.2s ease-in-out;
        }
        .comment-box.open, .related-box.open {
            transform: translateX(0);
        }
        .main-container {
            display: flex;
            gap: 1rem;
            align-items: flex-start;
            transition: width 0.2s ease-in-out;
        }
        .video-container {
            flex: 1 1 0;
            min-width: 0;
            width: auto;
            transition: width 0.2s ease-in-out;
        }
        .video-container.full {
            width: 100%;
        }
        .sidebar {
            flex: 0 0 18rem;
            width: 18rem;
            transition: transform 0.2s ease-in-out;
        }
        .sidebar.hidden {
            transform: translateX(100%);
        }
        .related-sidenone {
            display: none;
        }
        .related-sidenone.hidden {
            display: block;
        }
        .expand-sidebar-btn {
            position: fixed;
            bottom: 20px;
            right: 10px;
            background: #444;
            color: white;
            padding: 10px 15px;
            border-radius: 5px;
            cursor: pointer;
            display: none;
        }
        .expand-sidebar-btn.visible {
            display: block;
        }
        .toolbar {
            position: fixed;
            top: 0;
            right: -50%;
            width: 50%;
            background: rgba(51, 51, 51, 0.95);
            transition: right 0.2s;
            padding: 20px;
            z-index: 10;
        }
        .toolbar.open { right: 0; }
        .toggle-btn { cursor: pointer; padding: 10px; background: #444; color: white; border: none; border-radius: 5px; }
        .checkbox-container { display: flex; align-items: center; }
        .controlPanel {
            display: none;
        }
        .controlPanel.open { display: block; }
        .tab-button.active {
            background-color: #4a5568;
        }
        .tab-content {
            display: none;
        }
        .tab-content.active {
            display: block;
　　     }
        .loading-indicator {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            display: none;
            z-index: 10;
        }
        .loading-indicator img {
            width: 75px;
            height: 75px;
        }
        .mobile-action-box {
            display: none;
            margin-top: 1rem;
        }
        /* サイドバー非表示時（.full クラスが付与されている状態）にボタンを表示 */
        .video-container.full .mobile-action-box {
            display: block;
        }
    </style>
</head>
<body class="bg-gray-900 text-white">
    <header class="bg-gray-800 p-4 flex justify-between items-center">
        <form action="/wkt/s" method="get" class="w-1/2 relative" id="searchForm">
            <input type="text" name="q" id="searchbox" placeholder="検索" class="searchbox w-full p-2 pr-10 rounded bg-gray-700 text-white">
            <button type="button" id="clearBtn" class="absolute right-2 top-1/2 -translate-y-1/2 flex items-center justify-center h-6 w-6 rounded-full hover:bg-gray-400 text-white text-lg leading-none hidden">
             ×
            </button>
        </form>
        <button id="toggleToolbar" class="toggle-btn w-1/5">ツール</button>
    </header>
  
    <div class="toolbar w-1/2 ml-4" id="toolbar">
        <button id="closeToolbar" class="toggle-btn w-2/3 bg-gray-700 py-2 hover:text-white p-2 rounded mb-2 absolute top-4 right-4">閉じる</button>
        <nav class="mt-12">
            <button onclick="window.location.href='/wkt'" class="w-full bg-gray-700 py-2 hover:text-white p-2 rounded mb-2">ホーム</button>
            <button onclick="window.location.href='/wkt/trend'" class="w-full bg-gray-700 py-2 hover:text-white rounded mb-2">トレンド</button>
            <button onclick="window.location.href='/wkt/cl/fav'" class="w-full bg-gray-700 py-2 hover:text-white rounded mb-2">お気に入り</button>
            <button onclick="window.location.href='/wkt/cl/history'" class="w-full bg-gray-700 py-2 hover:text-white rounded mb-2">再生履歴</button>
            <button onclick="window.open('/wkt/back/vi/<%= videoId %>/maxresdefault.jpg', '_blank');" class="w-full bg-gray-700 py-2 hover:text-white p-2 rounded mb-2">サムネをダウンロード</button>
            <button onclick="window.open('<%- videoData.stream_url %>', '_blank');" class="w-full bg-gray-700 py-2 hover:text-white p-2 rounded mb-2">ストリームURLに移動</button>
            <button onclick="window.open('/other/xerox#/watch/<%= videoId %>', '_blank');" class="w-full bg-gray-700 py-2 hover:text-white p-2 rounded mb-2">XeroxYT-NTで視聴</button>
            <button onclick="window.open('/other/labo5#/watch?v=<%= videoId %>', '_blank');" class="w-full bg-gray-700 py-2 hover:text-white p-2 rounded mb-2">Re: LABO5で視聴</button>
            <button onclick="window.open('/other/player#?v=<%= videoId %>&playlist=<%= videoId %>', '_blank');" class="w-full bg-gray-700 py-2 hover:text-white p-2 rounded mb-2">YouTube 埋め込み再生ツールで視聴</button>
            <button onclick="window.open('/other/player#?v=<%= videoId %>&list=<%= videoInfo.channelId %>', '_blank');" class="w-full bg-gray-700 py-2 hover:text-white p-2 rounded mb-2">YouTube 埋め込み再生ツールでチャンネルの動画を視聴</button>
        </nav>
        <nav class="mt-4">
            <button onclick="window.location.href='/blog/b/wkthelp'" class="w-full bg-gray-700 py-2 hover:text-white p-2 rounded mb-2">ヘルプ</button>
        </nav>
    </div>
    
    <div class="max-w-6xl mx-auto p-4 main-container" id="mainContainer">
        <div class="video-container" id="videoContainer">
        <div class="relative">
        <div class="loading-indicator">
          <img src="https://www.benricho.org/loading_images/img-transparent/89-88.gif" alt="Loading...">
        </div>
          <video id="video" class="w-full h-auto max-h-screen" controls preload="auto" playsinline poster="/wkt/back/vi/<%= videoId %>/maxresdefault.jpg">
              <source id="videoSrc" src="<%- videoData.stream_url %>" type="video/mp4">
          </video>
        <audio id="audio" style="display: none;"></audio>
        <button id="erroreloadButton" class="hidden absolute top-1/2 left-1/2 z-50 -translate-x-1/2 -translate-y-1/2 bg-blue-600 text-white font-semibold py-2 px-4 rounded-xl shadow-lg hover:bg-blue-700 transition">🔄 動画を再読み込み</button>
        <div class="mobile-action-box">
            <button
                class="w-full bg-gray-700 py-2 rounded"
                onclick="document.getElementById('controlPanel').classList.toggle('open')">
                コントロール
            </button>
        </div>
        </div>
            <div class="flex items-start mt-4 p-4 bg-gray-800 rounded gap-3">
              <div class="flex-1 min-w-0">
                <% if (videoInfo.channels.length === 1) { %>
                  <div class="flex items-center gap-3">
                    <a href="/wkt/c/<%= videoInfo.channels[0].id %>" class="flex-shrink-0">
                      <img src="<%= videoInfo.channels[0].icon %>" alt="アイコン" class="w-12 h-12 rounded-full">
                    </a>
                    <div class="min-w-0">
                      <h2 class="text-lg font-bold"><a href="/wkt/c/<%= videoInfo.channels[0].id %>"><%= videoInfo.channels[0].name %></a></h2>
                      <p class="text-sm text-gray-400"><%= videoInfo.channels[0].subsc %></p>
                    </div>
                  </div>
                <% } else { %>
                  <ul class="space-y-3">
                    <% videoInfo.channels.forEach(function(ch) { %>
                      <li class="flex items-center gap-3">
                        <a href="<%= ch.id ? '/wkt/c/' + ch.id : '#' %>" class="flex-shrink-0">
                          <% if (ch.icon) { %>
                            <img src="<%= ch.icon %>" alt="<%= ch.name %>" class="w-12 h-12 rounded-full object-cover">
                          <% } else { %>
                            <div class="w-12 h-12 rounded-full bg-gray-600"></div>
                          <% } %>
                        </a>
                        <div class="min-w-0">
                          <% if (ch.id) { %>
                            <h2 class="text-lg font-bold"><a href="/wkt/c/<%= ch.id %>"><%= ch.name %></a></h2>
                          <% } else { %>
                            <h2 class="text-lg font-bold"><%= ch.name %></h2>
                          <% } %>
                          <% if (ch.subsc) { %><p class="text-sm text-gray-400"><%= ch.subsc %></p><% } %>
                        </div>
                      </li>
                    <% }); %>
                  </ul>
                <% } %>
              </div>
              <button id="favoriteBtn" class="flex-shrink-0 p-2 rounded-full bg-gray-500">
                <img id="favoriteIcon" src="https://wsrv.nl/?url=https://kotonohaworks.com/free-icons/wp-content/uploads/kkrn_icon_hoshi_4.png" alt="お気に入り" class="w-8 h-8">
              </button>
            </div>

    <div class="mt-4 p-4 bg-gray-800 rounded">
      <div class="mt-2 text-gray-400 text-sm">
          <p><%= videoInfo.viewCount %>  ・  <%= videoInfo.likeCount %>いいね  ・  <%= videoInfo.published %></p>
      </div>
    <div class="flex items-center justify-between">
        <h3 class="text-2xl font-bold"> 
          <a href="#mainContainer"><%= videoInfo.title %></a>
        </h3>
        <button class="ml-2 text-blue-500 hover:text-blue-300 text-sm" onclick="toggleDescription(this)">
            折りたたむ
        </button>
    </div>
    <div class="description mt-2">
        <p class="text-base text-gray-300 mt-1"><%- (videoInfo.description || "").replace(/\n/g, "<br>") %></p>
    </div>
    <!-- ダウンロードセクション -->
    <div class="mt-4 border-t border-gray-700 pt-4">
        <button id="downloadBtn" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded transition duration-200 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
            ダウンロード
        </button>
        <div id="downloadOptions" class="hidden mt-3 p-4 bg-gray-700 rounded-lg space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-300 mb-1">タイプ</label>
                    <select id="dlType" class="w-full bg-gray-800 border border-gray-600 rounded p-2 text-white">
                        <option value="both">動画 + 音声 (MP4)</option>
                        <option value="video">動画のみ (MP4/WebM)</option>
                        <option value="audio">音声のみ (MP3/M4A)</option>
                        <option value="image">画像のみ (サムネイル)</option>
                    </select>
                </div>
                <div id="dlQualityContainer">
                    <label class="block text-sm font-medium text-gray-300 mb-1">画質 / 形式</label>
                    <select id="dlQuality" class="w-full bg-gray-800 border border-gray-600 rounded p-2 text-white">
                    </select>
                </div>
            </div>
            <div class="flex justify-end gap-2">
                <button id="dlCancel" class="bg-gray-600 hover:bg-gray-500 text-white py-1 px-4 rounded">キャンセル</button>
                <button id="dlStart" class="bg-green-600 hover:bg-green-700 text-white py-1 px-4 rounded">保存を開始</button>
            </div>
            <p class="text-xs text-gray-400 mt-2">※Chromebook対応。ダウンロードは新しいタブで開かれます。</p>
        </div>
    </div>
   </div>
              
            <div class="mt-4 p-4 bg-gray-800 rounded">
                <h3 class="text-lg font-bold">コメント</h3>
                <div class="mt-2 space-y-2">
                <div id="commentError2" class="text-red-500 hidden"></div>
                <div id="commentsList2" class="mt-2 space-y-2">
                   <p>コメントを取得中...</p>
                </div>
                </div>

               <button id="retryButton" class="w-full bg-gray-700 py-2 rounded mt-2 hidden">再取得</button>
            </div>
            <div class="related-sidenone mt-4 p-4 bg-gray-800 rounded" id="related-sidenone">
            <h3 class="text-lg font-bold">関連動画</h3><br>
<% if (videoInfo.watch_next_feed && videoInfo.watch_next_feed.length > 0) { %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
            <% videoInfo.watch_next_feed.forEach(video => { %>
              <% if (video.type.endsWith("Video")) { %>
                <div class="result-item bg-gray-800 p-4 rounded-lg shadow hover:bg-gray-700 transition duration-200">
                    <a href="/wkt/watch/<%= video.id %>" class="block relative group">
                        <img loading="lazy" src="/wkt/back/vi/<%= video.id %>/mqdefault.jpg" alt="<%= video.title?.text || '動画' %>" class="w-full h-auto rounded aspect-video object-cover">
                        <% if (video.duration?.text) { %>
                            <span class="absolute bottom-1 right-1 bg-black bg-opacity-80 text-white text-xs px-1.5 py-0.5 rounded font-medium"><%= video.duration.text %></span>
                        <% } %>
                        <div class="absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-10 transition rounded"></div>
                    </a>
                    <div class="mt-3 flex items-start space-x-3">
                        <a href="<%= (video.author?.id && video.author.id !== 'N/A') ? '/wkt/c/' + video.author.id : '/wkt/watch/' + video.id %>" class="flex-shrink-0">
                            <% if (video.author?.thumbnails?.length) { %>
                            <% if (video.author.id === 'N/A') { %>
                            <img src="<%= video.author.thumbnails[0].url %>" alt="<%= video.author?.name || '' %>" class="w-9 h-9 rounded-full object-cover bg-gray-600 border border-gray-700">
                            <% } else { %>
                            <img src="/wkt/back/yt3<%- (new URL(video.author.thumbnails[0].url)).pathname %>" alt="<%= video.author?.name || '' %>" class="w-9 h-9 rounded-full object-cover bg-gray-600 border border-gray-700">
                            <% } %>
                            <% } else { %>
                            <div class="w-9 h-9 rounded-full bg-gray-600 border border-gray-700"></div>
                            <% } %>
                        </a>
                        <div class="flex-1 min-w-0">
                            <a href="/wkt/watch/<%= video.id %>">
                                <p class="text-white font-bold text-sm leading-snug line-clamp-2 mb-1 hover:text-blue-400 transition"><%= video.title?.text || '' %></p>
                            </a>
                            <a href="<%= (video.author?.id && video.author.id !== 'N/A') ? '/wkt/c/' + video.author.id : '/wkt/watch/' + video.id %>" class="text-gray-400 text-xs hover:text-white transition mb-0.5 block truncate"><%= video.author?.name || '' %></a>
                            <p class="text-gray-500 text-xs"><%= video.short_view_count?.text || video.view_count?.text || "" %><% if (video.published?.text) { %> • <%= video.published.text %><% } %></p>
                        </div>
                    </div>
                </div>
              <% } else if (video.type.endsWith("Playlist")) { %>
                <div class="bg-gray-800 p-2 rounded">
                    <a href="/wkt/p/<%= video.id %>">
                        <img src="/wkt/back/vi/<%= video?.endpoint?.payload?.videoId || video.first_videos[0]?.id %>/mqdefault.jpg" alt="サムネ" class="w-full h-auto rounded">
                    </a>
                    <p class="text-sm font-bold mt-1">
                        <a href="/wkt/p/<%= video.id %>"><%= video.title.text %></a>
                    </p>
                    <p class="text-xs text-gray-400">動画数: <%= video.video_count?.text %></p>
                </div>
              <% } else if (video.type.endsWith("Channel")) { %>
                <div class="bg-gray-800 p-2 rounded">
                    <a href="/wkt/c/<%= video.author.id %>">
                        <% if (video.author?.thumbnails?.length) { %>
                        <img src="/wkt/back/yt3<%- (new URL(video.author.thumbnails[0].url)).pathname %>" alt="チャンネルアイコン" class="w-16 h-16 rounded-full mx-auto">
                        <% } %>
                    </a>
                    <p class="text-sm font-bold mt-1 text-center">
                        <a href="/wkt/c/<%= video.author.id %>" target="_top"><%= video.author.name %></a>
                    </p>
                    <p class="text-xs text-gray-400 text-center">
                        登録者数: <%= video.subscriber_count?.text %>
                    </p>
                </div>
              <% } %>
            <% }); %>
        </div>
<% } %>
            </div>
        </div>
            
<div id="controlPanel" class="controlPanel bg-gray-900 text-white p-6 rounded-lg shadow-lg w-96 fixed bottom-10 right-10 border border-gray-700 z-50">
    <button id="closeControlPanel" class="absolute top-2 right-2 text-gray-400 hover:text-white text-2xl">×</button>
    <div class="tab-header flex border-b border-gray-700 mb-4">
        <div id="tabControl" class="tab-button active px-4 py-2 cursor-pointer text-white bg-gray-800 rounded-t-lg" data-target="controlTab">コントロール</div>
        <div id="tabSettings" class="tab-button px-4 py-2 cursor-pointer text-gray-400 hover:text-white rounded-t-lg" data-target="settingsTab">設定</div>
    </div>
    <div id="controlTab" class="tab-content active">
        <div class="control-section mb-4">
            <button id="reloadVideo" class="control-button w-full bg-gray-700 py-2 hover:text-white p-2 rounded mb-2">🔄 再読み込み</button>
            <div class="checkbox-container w-full bg-gray-700 py-2 hover:text-white rounded mb-2 flex items-center justify-center">
                <label for="loopToggle" class="ml-2 cursor-pointer select-none">🔁 ループ再生</label>
                <input type="checkbox" id="loopToggle" class="form-checkbox text-green-500 ml-2">
            </div>
            <!-- 再生モード -->
            <div class="control-section mb-4">
                <label class="block mb-2 text-sm font-medium text-gray-400">再生モード:</label>
                <div class="flex flex-col gap-2">
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="radio" name="playMode" value="both" id="playModeBoth" checked class="text-blue-500">
                        <span class="text-sm">動画 + 音声</span>
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="radio" name="playMode" value="videoOnly" id="playModeVideo" class="text-blue-500">
                        <span class="text-sm">映像のみ</span>
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="radio" name="playMode" value="audioOnly" id="playModeAudio" class="text-blue-500">
                        <span class="text-sm">音声のみ</span>
                    </label>
                </div>
            </div>
        </div>
        <% if (videoData.streamUrls && videoData.streamUrls.length > 0) { %>
        <div class="control-section mb-4">
            <label class="block mb-2">画質を選択:
                <select id="qualitySelect" class="w-full bg-gray-800 text-white p-2 rounded">
                    <option value="<%= videoData.stream_url %>" data-container="mp4" data-is-auto="true">統合ストリーム</option>
                    <% if (videoData.streamUrls && videoData.streamUrls.length > 0) { %>
                        <% videoData.streamUrls.forEach(function(stream) { %>
                            <option value="<%= stream.url %>">
                                <%= stream.resolution %><%= stream.fps ? stream.fps : '' %> (<%= stream.container %>)
                            </option>
                        <% }); %>
                    <% } %>
                </select>
            </label>

            <label class="block mb-2">音声を選択:
                <select id="audioSelect" class="w-full bg-gray-800 text-white p-2 rounded">
                    <% if (videoData.audioUrls && videoData.audioUrls.length > 0) { %>
                        <% videoData.audioUrls.forEach(function(audio) { %>
                            <option value="<%= audio.url %>"><%= audio.name %></option>
                        <% }); %>
                    <% } else if (videoData.audioUrl) { %>
                        <option value="<%= videoData.audioUrl %>">Default</option>
                    <% } else { %>
                        <option value="">オーディオなし</option>
                    <% } %>
                </select>
            </label>
            <button id="qualityReset" class="control-button w-full bg-gray-700 py-2 hover:text-white p-2 rounded mb-2">画質をリセット</button>
        </div>
        <% } %>
        <div class="control-section mb-4">
            <p class="block mb-2">使用したサーバー: <strong><%= baseUrl.replace('https://', '').replace('.glitch.me', '') %></strong></p>
            <label class="block mb-2">サーバーを変える:
                <select id="serverSelect" class="w-full bg-gray-800 text-white p-2 rounded">
                    <optgroup label="🐇 高速サーバー群">
                        <option value="invidious" <%= baseUrl === 'invidious' ? 'selected' : '' %>>Invidious API</option>
                        <option value="acethinker" <%= baseUrl === 'acethinker' ? 'selected' : '' %>>AceThinker API</option>
                        <option value="siawaseok" <%= baseUrl === 'siawaseok' ? 'selected' : '' %>>SiaTube API</option>
                        <option value="yudlp" <%= baseUrl === 'yudlp' ? 'selected' : '' %>>YuZuTube API</option>
                        <option value="senninytdlp" <%= baseUrl === 'senninytdlp' ? 'selected' : '' %>>SenninTube Plus API</option>
                        <option value="ytdlpinstance-vercel" <%= baseUrl === 'ytdlpinstance-vercel' ? 'selected' : '' %>>KatuoTube API</option>
                        <option value="min-tube2-api" <%= baseUrl === 'min-tube2-api' ? 'selected' : '' %>>MIN-Tube2 API</option>
                    </optgroup>
                    <optgroup label="🐢 低速サーバー群">
                        <option value="simple-yt-stream" <%= baseUrl === 'simple-yt-stream' ? 'selected' : '' %>>Wista Stream API</option>
                        <option value="xeroxyt-nt-apiv1" <%= baseUrl === 'xeroxyt-nt-apiv1' ? 'selected' : '' %>>XeroxYT-NT APIv1</option>
                    </optgroup>
                    <optgroup label="🎲 予備サーバー群">
                        <option value="freemake" <%= baseUrl === 'freemake' ? 'selected' : '' %>>Freemake API</option>
                    </optgroup>
                </select>
            </label>
            <button id="changeServer" class="control-button w-full bg-gray-700 py-2 hover:text-white p-2 rounded mb-2">🔃 サーバーを変更</button>
        </div>
    </div>
<div id="settingsTab" class="tab-content hidden">
    <h2 class="text-lg font-semibold mb-3">再生方法の変更</h2>
    <p class="mb-4 text-gray-600">動画のデフォルトの再生方法を設定できます。埋め込みで見れるなら埋め込みで見た方が良いですよ。</p>
    <p class="mb-4 text-gray-600">現在の再生方法: 通常</p>
    <div class="control-section mb-4">
        <div class="flex flex-col">
            <label class="flex items-start mb-2">
                <input type="radio" name="playbackMode" value="normal" class="mr-2 mt-1">
                <div>
                    <strong>通常</strong> - ストリームURLを用いて再生します。最初のデフォルト設定で、ほとんどの人が使用できます。
                </div>
            </label>
            <label class="flex items-start mb-2">
                <input type="radio" name="playbackMode" value="edu" class="mr-2 mt-1">
                <div>
                    <strong>Education</strong> - YouTubeEducationを埋め込んで再生を行います。一部の人が使用できます。
                    <a href="/wkt/yt/edu/<%= videoId %>" class="text-blue-500 underline" target="_blank">再生できるか確かめる</a>。
                </div>
            </label>
            <label class="flex items-start mb-2">
                <input type="radio" name="playbackMode" value="nocookie" class="mr-2 mt-1">
                <div>
                    <strong>Nocookie</strong> - YouTube-Nocookieを埋め込んで再生を行います。こちらも一部の人が使用できます。
                    <a href="/wkt/yt/nocookie/<%= videoId %>" class="text-blue-500 underline" target="_blank">再生できるか確かめる</a>。
                </div>
            </label>
        </div>
    </div>
    
    <button id="saveSettings" class="control-button w-full bg-gray-700 py-2 hover:text-white p-2 rounded mb-2">💾 設定を保存</button>
</div>
</div>

        <div class="sidebar w-1/4 ml-4" id="sidebar">
<div id="commentBox" class="fixed top-0 right-0 w-1/2 h-full bg-gray-800 p-4 shadow-lg flex flex-col comment-box z-40">
    <div class="sticky top-0 bg-gray-800 p-0 z-10">
        <button id="closeComments" class="w-full bg-gray-700 py-2 rounded mb-2">閉じる</button>
    </div>
    <div class="flex-1 overflow-y-auto">
        <div id="commentError1" class="text-red-500 hidden"></div>
        <div id="commentsList1" class="mt-2 space-y-2">
            <p>コメントを取得中...</p>
        </div>
        <button id="closeComments2" class="w-full bg-gray-700 py-2 rounded mt-2">閉じる</button>
    </div>
</div>

  <div id="dougaBox" class="fixed top-0 right-0 w-1/2 h-full bg-gray-800 p-4 shadow-lg overflow-y-auto related-box z-40">
    <div class="sticky top-0 z-10 bg-gray-800 pb-2 flex justify-end">
    <form id="umekomisearchForm" class="w-1/2 mr-2 mb-2">
      <input type="text" name="q" id="searchInput" placeholder="検索" class="searchInput w-full p-2 rounded bg-gray-700 text-white">
    </form>
    <button id="closedouga" class="w-1/2 bg-gray-700 py-2 rounded mb-2 ml-auto text-center">閉じる</button>
    </div>
    <div class="flex-1 overflow-y-auto" id="dougaBoxcon">
                <h3 class="text-lg font-bold">関連動画</h3>
<% if (videoInfo.watch_next_feed?.length) { %>
<% videoInfo.watch_next_feed.forEach(video => { %>
<div class="mt-2 space-y-4">
  <% if (!video) return; %>
  <% if (video.type.endsWith("Video")) { %>
    <div class="result-item bg-gray-800 p-4 rounded-lg shadow hover:bg-gray-700 transition duration-200">
      <a href="/wkt/watch/<%= video.id %>" class="block relative group">
        <img loading="lazy" src="/wkt/back/vi/<%= video.id %>/mqdefault.jpg" alt="<%= video.title?.text || '動画' %>" class="w-full h-auto rounded aspect-video object-cover">
        <% if (video.duration?.text) { %>
          <span class="absolute bottom-1 right-1 bg-black bg-opacity-80 text-white text-xs px-1.5 py-0.5 rounded font-medium"><%= video.duration.text %></span>
        <% } %>
        <div class="absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-10 transition rounded"></div>
      </a>
      <div class="mt-3 flex items-start space-x-3">
        <a href="<%= (video.author?.id && video.author.id !== 'N/A') ? '/wkt/c/' + video.author.id : '/wkt/watch/' + video.id %>" class="flex-shrink-0">
          <% if (video.author?.thumbnails?.length) { %>
          <% if (video.author.id === 'N/A') { %>
          <img src="<%= video.author.thumbnails[0].url %>" alt="<%= video.author?.name || '' %>" class="w-9 h-9 rounded-full object-cover bg-gray-600 border border-gray-700">
          <% } else { %>
          <img src="/wkt/back/yt3<%- (new URL(video.author.thumbnails[0].url)).pathname %>" alt="<%= video.author?.name || '' %>" class="w-9 h-9 rounded-full object-cover bg-gray-600 border border-gray-700">
          <% } %>
          <% } else { %>
          <div class="w-9 h-9 rounded-full bg-gray-600 border border-gray-700"></div>
          <% } %>
        </a>
        <div class="flex-1 min-w-0">
          <a href="/wkt/watch/<%= video.id %>">
            <p class="text-white font-bold text-sm leading-snug line-clamp-2 mb-1 hover:text-blue-400 transition"><%= video.title?.text || '' %></p>
          </a>
          <a href="<%= (video.author?.id && video.author.id !== 'N/A') ? '/wkt/c/' + video.author.id : '/wkt/watch/' + video.id %>" class="text-gray-400 text-xs hover:text-white transition mb-0.5 block truncate"><%= video.author?.name || '' %></a>
          <p class="text-gray-500 text-xs"><%= video.short_view_count?.text || video.view_count?.text || "" %><% if (video.published?.text) { %> • <%= video.published.text %><% } %></p>
        </div>
      </div>
    </div>
  <% } else if (video.type.endsWith("Playlist")) { %>
    <div class="bg-gray-800 p-2 rounded">
      <a href="/wkt/p/<%= video.id %>">
        <img src="/wkt/back/vi/<%= video?.endpoint?.payload?.videoId || video.first_videos[0]?.id %>/mqdefault.jpg" alt="サムネ" class="w-full h-auto rounded">
      </a>
      <p class="text-sm font-bold mt-1">
        <a href="/wkt/p/<%= video.id %>"><%= video.title.text %></a>
      </p>
      <p class="text-xs text-gray-400">動画数: <%= video.video_count?.text %></p>
    </div>
  <% } else if (video.type.endsWith("Channel")) { %>
    <div class="bg-gray-800 p-2 rounded">
      <a href="/wkt/c/<%= video.author.id %>">
        <% if (video.author?.thumbnails?.length) { %>
        <img src="/wkt/back/yt3<%- (new URL(video.author.thumbnails[0].url)).pathname %>" alt="チャンネルアイコン" class="w-16 h-16 rounded-full mx-auto">
        <% } %>
      </a>
      <p class="text-sm font-bold mt-1 text-center">
        <a href="/wkt/c/<%= video.author.id %>" target="_top"><%= video.author.name %></a>
      </p>
      <p class="text-xs text-gray-400 text-center">
        登録者数: <%= video.subscriber_count?.text %>
      </p>
    </div>
  <% } %>
</div>
<% }); %><% } %>
</div>
<button id="closedouga2" class="w-full bg-gray-700 py-2 rounded mb-2">閉じる</button>
            </div>
            <button id="hideSidebar" class="w-full bg-gray-700 py-2 rounded">▶ サイドバーを隠す</button>
            <button id="toggleComments" class="mt-4 w-full bg-gray-700 py-2 rounded">コメントを開く</button>
        </div>
    </div>

    <div style="height:480px;" class="w-full max-w-3xl mx-auto mt-8 px-4">
        <script src="//accaii.com/wktplus/widget.js" async></script>
    </div>

    <script>
    const video = document.getElementById('video');
    const audio = document.getElementById('audio');
    const videoSrc = document.getElementById('videoSrc');

    // ダウンロード機能
    const videoDataDL = <%- JSON.stringify(videoData) %>;
    $('#downloadBtn').on('click', function() {
        $('#downloadOptions').toggleClass('hidden');
        updateDownloadQualities();
    });
    $('#dlCancel').on('click', function() {
        $('#downloadOptions').addClass('hidden');
    });
    $('#dlType').on('change', updateDownloadQualities);

    function updateDownloadQualities() {
        const type = $('#dlType').val();
        const $select = $('#dlQuality');
        $select.empty();
        function resLabel(res) {
            if (!res) return res;
            if (res.includes('2160')) return '4K (2160p)';
            return res;
        }
        if (type === 'both') {
            if (videoDataDL.stream_url) $select.append('<option value="' + videoDataDL.stream_url + '">標準画質 (統合MP4)</option>');
            if (videoDataDL.streamUrls) {
                videoDataDL.streamUrls.forEach(function(s) {
                    if (s.container === 'mp4' && !s.url.includes('manifest')) {
                        $select.append('<option value="' + s.url + '">' + resLabel(s.resolution) + ' (' + s.container + ')</option>');
                    }
                });
            }
        } else if (type === 'video') {
            if (videoDataDL.streamUrls) {
                videoDataDL.streamUrls.forEach(function(s) {
                    $select.append('<option value="' + s.url + '">' + resLabel(s.resolution) + ' (' + s.container + ')</option>');
                });
            }
            if (videoDataDL.highstreamUrl) $select.append('<option value="' + videoDataDL.highstreamUrl + '">高画質 WebM (映像のみ)</option>');
        } else if (type === 'audio') {
            if (videoDataDL.audioUrls && videoDataDL.audioUrls.length > 0) {
                videoDataDL.audioUrls.forEach(function(a) {
                    $select.append('<option value="' + a.url + '">' + (a.label || a.name || '音声') + ' (' + (a.container || 'm4a') + ')</option>');
                });
            } else if (videoDataDL.audioUrl) {
                $select.append('<option value="' + videoDataDL.audioUrl + '">標準音声 (m4a)</option>');
            }
            $select.append('<option value="https://www.youtube.com/watch?v=<%= videoId %>">YouTubeで開く (外部変換用)</option>');
        } else if (type === 'image') {
            $select.append('<option value="/wkt/back/vi/<%= videoId %>/maxresdefault.jpg">最大サイズ / 4K (JPG)</option>');
            $select.append('<option value="/wkt/back/vi/<%= videoId %>/hqdefault.jpg">高画質 (JPG)</option>');
            $select.append('<option value="/wkt/back/vi/<%= videoId %>/mqdefault.jpg">中画質 (JPG)</option>');
        }
        if ($select.children().length === 0) $select.append('<option value="">利用可能な形式がありません</option>');
    }

    $('#dlStart').on('click', function() {
        const url = $('#dlQuality').val();
        if (!url) return;
        if (confirm('ダウンロードを開始しますか？\n※著作権に注意し、私的利用の範囲内でご利用ください。')) {
            window.open(url, '_blank');
            $('#downloadOptions').addClass('hidden');
        }
    });

    // 再生モード切り替え
    $('input[name="playMode"]').on('change', function() {
        const mode = $(this).val();
        const videoEl = document.getElementById('video');
        const audioEl = document.getElementById('audio');
        if (mode === 'both') {
            videoEl.style.display = '';
            videoEl.muted = false;
            if (audioEl.src && audioEl.src !== window.location.href) {
                audioEl.play();
            }
        } else if (mode === 'videoOnly') {
            videoEl.style.display = '';
            videoEl.muted = false;
            audioEl.pause();
            audioEl.src = '';
        } else if (mode === 'audioOnly') {
            videoEl.style.display = 'none';
            if (audioEl.src && audioEl.src !== window.location.href) {
                audioEl.play();
            } else if (videoDataDL.audioUrl) {
                audioEl.src = videoDataDL.audioUrl;
                audioEl.load();
                audioEl.play();
            }
        }
    });

    // 4K ラベル強調
    $('#qualitySelect option').each(function() {
        if ($(this).text().includes('2160')) {
            $(this).text('4K - ' + $(this).text());
        }
    });

    $(document).ready(function() {
        // コメント取得
        const videoId = "<%= videoId %>";
        async function fetchComments() {
            $('#commentsList2').html("<p>コメントを取得中...</p>");
            try {
                const response = await fetch("/wkt/back/comment/<%= videoId %>");
                if (!response.ok) throw new Error("サーバーエラー");
                const responseText = await response.text();
                $('#commentsList2').html(responseText);
            } catch (error) {
                console.error("エラー:", error);
                $('#commentsList2').html('<p class="text-red-500">コメントの取得に失敗しました</p>');
                $('#retryButton').removeClass('hidden');
            }
        }
        $('#retryButton').click(fetchComments);
        fetchComments();

        // ツールバー
        const toolbar = document.getElementById('toolbar');
        const toggleToolbar = document.getElementById('toggleToolbar');
        const closeToolbar = document.getElementById('closeToolbar');

        toggleToolbar.addEventListener('click', () => {
            toolbar.classList.toggle('open');
        });

        closeToolbar.addEventListener('click', () => {
            toolbar.classList.remove('open');
        });

        // サイドバー
        const sidebar = document.getElementById('sidebar');
        const hideSidebar = document.getElementById('hideSidebar');
        const expandSidebar = document.getElementById('expandSidebar');

        hideSidebar.addEventListener('click', () => {
            sidebar.classList.add('hidden');
            document.getElementById('videoContainer').classList.add('full');
            expandSidebar.classList.add('visible');
            document.getElementById('related-sidenone').classList.add('hidden');
            localStorage.setItem("sidebarHidden", "true");
        });

        expandSidebar.addEventListener('click', () => {
            sidebar.classList.remove('hidden');
            document.getElementById('videoContainer').classList.remove('full');
            expandSidebar.classList.remove('visible');
            document.getElementById('related-sidenone').classList.remove('hidden');
            localStorage.setItem("sidebarHidden", "false");
        });

        // コメントボックス
        const commentBox = document.getElementById('commentBox');
        const toggleComments = document.getElementById('toggleComments');
        const closeComments = document.getElementById('closeComments');
        const closeComments2 = document.getElementById('closeComments2');

        toggleComments.addEventListener('click', async () => {
            commentBox.classList.add('open');
            const commentsList1 = document.getElementById('commentsList1');
            const commentError1 = document.getElementById('commentError1');
            
            commentsList1.innerHTML = "<p>コメントを取得中...</p>";
            commentError1.classList.add('hidden');

            try {
                const response = await fetch(`/wkt/back/comment/${videoId}`);
                if (!response.ok) throw new Error();
                const data = await response.text();
                commentsList1.innerHTML = data;
            } catch (err) {
                commentError1.textContent = "コメントの取得に失敗しました。";
                commentError1.classList.remove('hidden');
                commentsList1.innerHTML = "";
            }
        });

        closeComments.addEventListener('click', () => commentBox.classList.remove('open'));
        closeComments2.addEventListener('click', () => commentBox.classList.remove('open'));

        // 関連動画ボックス
        const dougaBox = document.getElementById('dougaBox');
        const closedouga = document.getElementById('closedouga');
        const closedouga2 = document.getElementById('closedouga2');

        closedouga.addEventListener('click', () => dougaBox.classList.remove('open'));
        closedouga2.addEventListener('click', () => dougaBox.classList.remove('open'));

        // 画質変更
        const qualitySelect = document.getElementById('qualitySelect');
        if (qualitySelect) {
            qualitySelect.addEventListener('change', () => {
                const selectedOption = qualitySelect.options[qualitySelect.selectedIndex];
                const newUrl = selectedOption.value;
                const isAuto = selectedOption.getAttribute('data-is-auto') === 'true';
                const container = selectedOption.getAttribute('data-container') || 'mp4';

                const currentTime = video.currentTime;
                video.pause();

                videoSrc.src = newUrl;
                videoSrc.type = `video/${container}`;

                if (isAuto) {
                    audio.src = "";
                } else {
                    audio.src = document.getElementById('audioSelect').value;
                }

                video.load();
                if (audio.src) {
                    audio.load();
                    audio.currentTime = currentTime;
                }
                video.currentTime = currentTime;
                video.play();
            });
        }

        // サーバー変更
        document.getElementById('changeServer').addEventListener('click', () => {
            const server = document.getElementById('serverSelect').value;
            window.location.href = `/wkt/watch/${videoId}?server=${server}`;
        });

        // 設定保存
        document.getElementById('saveSettings').addEventListener('click', () => {
            const mode = document.querySelector('input[name="playbackMode"]:checked').value;
            document.cookie = `playbackMode=${mode}; path=/; max-age=31536000`;
            showMessage("設定を保存しました。");
            setTimeout(() => location.reload(), 1000);
        });

        // コントロールパネル
        const controlPanel = document.getElementById('controlPanel');
        const closeControlPanel = document.getElementById('closeControlPanel');
        const tabButtons = document.querySelectorAll('.tab-button');
        const tabContents = document.querySelectorAll('.tab-content');

        closeControlPanel.addEventListener('click', () => {
            controlPanel.classList.remove('open');
        });

        tabButtons.forEach(button => {
            button.addEventListener('click', () => {
                const target = button.getAttribute('data-target');
                tabButtons.forEach(btn => btn.classList.remove('active', 'bg-gray-800', 'text-white'));
                tabButtons.forEach(btn => btn.classList.add('text-gray-400'));
                button.classList.add('active', 'bg-gray-800', 'text-white');
                button.classList.remove('text-gray-400');

                tabContents.forEach(content => content.classList.add('hidden'));
                document.getElementById(target).classList.remove('hidden');
            });
        });
    });

    // 履歴
    const videoId = "<%= videoId %>";
    const channelId = "<%= videoInfo.channelId %>";
    const channelName = "<%= videoInfo.channelName %>";
    const videoTitle = "<%= videoInfo.title %>";

    function saveToHistory(videoId, channelId, channelName, videoTitle) {
        let history = getHistoryFromLocalStorage();
        const historyIndex = history.findIndex(track => track.videoId === videoId);
        if (historyIndex !== -1) {
            history.splice(historyIndex, 1);
        }
        if (history.length >= 30) {
            history.shift();
        }
        history.push({ videoId, channelId, channelName, videoTitle });
        localStorage.setItem("wakametubehistory", JSON.stringify(history));
    }

    function getHistoryFromLocalStorage() {
        const historyData = localStorage.getItem("wakametubehistory");
        try {
            return historyData ? JSON.parse(historyData) : [];
        } catch (error) {
            console.error('Error parsing history from localStorage:', error);
            return [];
        }
    }
      
    //お気に入り
    function getFavoritesFromLocalStorage() {
      return JSON.parse(localStorage.getItem("wakametubefavorites") || "[]");
    }
    function saveToFavorites(videoId, channelId, channelName, videoTitle) {
      let favorites = getFavoritesFromLocalStorage();
      const favIcon = document.getElementById("favoriteIcon");
      const favIndex = favorites.findIndex(track => track.videoId === videoId);
      if (favIndex !== -1) {
        favorites.splice(favIndex, 1);
        showMessage(`${videoTitle}の<a href="/wkt/cl/fav" style='color: #60a5fa;'>お気に入り</a>を解除しました☑️`);
      } else {
        favorites.push({ videoId, channelId, channelName, videoTitle });
        showMessage(`${videoTitle}を<a href="/wkt/cl/fav" style='color: #60a5fa;'>お気に入り</a>に追加しました☑️`);
      }
      localStorage.setItem("wakametubefavorites", JSON.stringify(favorites));
    }
    async function checkfav() {
      const favBtn = document.getElementById("favoriteBtn");
      const favIcon = document.getElementById("favoriteIcon");
      let favorites = getFavoritesFromLocalStorage();
      let isFavorited;
      if(favorites){
        isFavorited = favorites.some(track => track.videoId === videoId);
      }
      favIcon.src = isFavorited ? "https://wsrv.nl/?url=https://kotonohaworks.com/free-icons/wp-content/uploads/kkrn_icon_hoshi_1.png" : "https://wsrv.nl/?url=https://kotonohaworks.com/free-icons/wp-content/uploads/kkrn_icon_hoshi_4.png";
    }
    checkfav()
    document.getElementById("favoriteBtn").addEventListener("click", function() {
      saveToFavorites(videoId, channelId, channelName, videoTitle);
      const favIcon = document.getElementById("favoriteIcon");
      let updatedFavorites = getFavoritesFromLocalStorage();
      let nowFavorited;
      if(updatedFavorites){
        nowFavorited = updatedFavorites.some(track => track.videoId === videoId);
      }
      favIcon.src = nowFavorited ? "https://wsrv.nl/?url=https://kotonohaworks.com/free-icons/wp-content/uploads/kkrn_icon_hoshi_1.png" : "https://wsrv.nl/?url=https://kotonohaworks.com/free-icons/wp-content/uploads/kkrn_icon_hoshi_4.png";
    });
      
    // 概要
    function toggleDescription(button) {
        const description = button.closest('div').nextElementSibling;

        if (description.classList.contains('hidden')) {
            description.classList.remove('hidden');
            button.textContent = '折りたたむ';
        } else {
            description.classList.add('hidden');
            button.textContent = '表示する';
        }
    }
      
    //ショトカ
    document.addEventListener('keydown', function(event) {
        const activeElement = document.activeElement;
        if (activeElement.tagName === 'INPUT' || activeElement.tagName === 'TEXTAREA') {
            return;
        }
        if (event.code === 'Space') {
            event.preventDefault();
            if (video.paused) {
                video.play();
            } else {
                video.pause();
            }
        }
        if (event.key === 'f' || event.key === 'F') {
            event.preventDefault();
            toggleFullScreen();
        }
        if (event.key === 'ArrowRight') {
            video.currentTime += 10;
        } 
        if (event.key === 'ArrowLeft') {
            video.currentTime -= 10;
        }
    });
    function toggleFullScreen() {
        if (!document.fullscreenElement) {
            if (video.requestFullscreen) {
                video.requestFullscreen();
            } else if (video.mozRequestFullScreen) {
                video.mozRequestFullScreen();
            } else if (video.webkitRequestFullscreen) {
                video.webkitRequestFullscreen();
            } else if (video.msRequestFullscreen) {
                video.msRequestFullscreen();
            }
        } else {
            if (document.exitFullscreen) {
                document.exitFullscreen();
            } else if (document.mozCancelFullScreen) {
                document.mozCancelFullScreen();
            } else if (document.webkitExitFullscreen) {
                document.webkitExitFullscreen();
            } else if (document.msExitFullscreen) {
                document.msExitFullscreen();
            }
        }
    }
      
    // ページ読み込み
    window.addEventListener("load", function() {
        const tutorialok = localStorage.getItem('tutorialCompleted');
        if (!tutorialok) {
          showTutorial();
        } else if (tutorialok === "true"){
          showMessage("ヒント:<br>右側のコントロールボタンから画質を変更できます！");
          localStorage.setItem('tutorialCompleted', 'ok');
        }
        // バックエンドからエラーメッセージが渡されているかチェック
        const fallbackMsg = "<%= typeof fallbackMessage !== 'undefined' ? fallbackMessage : '' %>";
        if (fallbackMsg !== "") {
          // 渡されていた場合、そのメッセージ（Invidious APIを使用しました）を表示
          showerrorMessage(fallbackMsg);
        }
        saveToHistory(videoId, channelId, channelName, videoTitle);
    });
      
    function showTutorial() {
        const tutorialOverlay = document.createElement('div');
        tutorialOverlay.id = "tutorialOverlay";
        tutorialOverlay.style.position = 'fixed';
        tutorialOverlay.style.top = '0';
        tutorialOverlay.style.left = '0';
        tutorialOverlay.style.width = '100vw';
        tutorialOverlay.style.height = '100vh';
        tutorialOverlay.style.backgroundColor = 'rgba(0, 0, 0, 0.7)';
        tutorialOverlay.style.display = 'flex';
        tutorialOverlay.style.justifyContent = 'center';
        tutorialOverlay.style.alignItems = 'center';
        tutorialOverlay.style.zIndex = '1000';
        tutorialOverlay.innerHTML = `
            <div class="bg-gray-800 text-white p-6 rounded-lg shadow-xl w-3/4 md:w-1/2 lg:w-1/3 text-center">
                <p class="text-lg mb-6">あなたにとって最適な再生方法を設定するために協力してください！</p>
                <div class="space-y-4">
                <button id="startTutorialBtn" class="w-full bg-gray-700 py-2 rounded">設定する</button>
                <button id="skipBtn0" class="w-full bg-gray-700 py-2 rounded">設定をスキップ</button>
                </div>
            </div>
        `;
        document.body.appendChild(tutorialOverlay);
        document.getElementById('startTutorialBtn').addEventListener('click', function() {
            tutorialOverlay.remove();
            showPlaybackSettings("https://www.youtube-nocookie.com/embed/nZTLOPMF_Lo?autoplay=1&amp;mute=0&rel=0&playlist=nZTLOPMF_Lo&amp;origin=https%3A%2F%2Fwww.youtube.com", "nocookie");
        });
        document.getElementById('skipBtn0').addEventListener('click', function() {
            localStorage.setItem('tutorialCompleted', 'true');
            tutorialOverlay.remove();
            showMessage("再生方法をNormalに設定しました。<br>再生方法の変更は「コントロール」ボタンからいつでも行えます。");
        });
    }
      
    async function showPlaybackSettings(iframeurl, mode) {
        const settingsOverlay = document.createElement('div');
        settingsOverlay.id = "settingsOverlay";
        settingsOverlay.style.position = 'fixed';
        settingsOverlay.style.top = '0';
        settingsOverlay.style.left = '0';
        settingsOverlay.style.width = '100vw';
        settingsOverlay.style.height = '100vh';
        settingsOverlay.style.backgroundColor = 'rgba(0, 0, 0, 0.7)';
        settingsOverlay.style.display = 'flex';
        settingsOverlay.style.justifyContent = 'center';
        settingsOverlay.style.alignItems = 'center';
        settingsOverlay.style.zIndex = '1001';
        settingsOverlay.innerHTML = `
            <div class="bg-gray-800 text-white p-6 rounded-lg shadow-xl w-3/4 md:w-1/2 lg:w-1/3 text-center">
                <p class="text-lg mb-6">下に動画は表示されていますか？</p>
                <iframe id="videoIframe" class="w-full h-64 mb-4" frameborder="0" allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
                <div class="space-y-4">
                    <button id="canPlayBtn" class="w-full bg-gray-700 py-2 rounded">再生できる</button>
                    <button id="cannotPlayBtn" class="w-full bg-gray-700 py-2 rounded">再生できない</button>
                    <button id="skipBtn" class="w-full bg-gray-700 py-2 rounded">設定をスキップ</button>
                </div>
            </div>
        `;
        document.body.appendChild(settingsOverlay);
        const iframe = document.getElementById('videoIframe');
        iframe.src = iframeurl;

        document.getElementById('canPlayBtn').addEventListener('click', function() {
            localStorage.setItem('tutorialCompleted', 'true');
            document.cookie = `playbackMode=${mode}; path=/; max-age=31536000`;
            if(mode == "nocookie"){
              showMessage("再生方法をNocookieに設定しました。");
              window.location.href = `/wkt/yt/nocookie/<%= videoId %>?tu=true`;
            } else{
              showMessage("再生方法をEducationに設定しました。");
              window.location.href = `/wkt/yt/edu/<%= videoId %>?tu=true`;
            }
        });
        document.getElementById('cannotPlayBtn').addEventListener('click',async function() {
            if (mode == "nocookie"){
              settingsOverlay.remove();
              showMessage("必要なデータを取得中です");
              const ytinfo3 = await fetch('/wkt/yt/edurl', { method: 'GET' });
              const ytinfo = await ytinfo3.text();
              showPlaybackSettings(`https://www.youtubeeducation.com/embed/nZTLOPMF_Lo${ytinfo}&playlist=nZTLOPMF_Lo`, "edu");
            } else {
              localStorage.setItem('tutorialCompleted', 'true');
              settingsOverlay.remove();
              showMessage("再生方法をNormalに設定しました。<br>再生方法の変更は「コントロール」ボタンからいつでも行えます。");
            }
        });
        document.getElementById('skipBtn').addEventListener('click', function() {
            localStorage.setItem('tutorialCompleted', 'true');
            settingsOverlay.remove();
            showMessage("再生方法をNormalに設定しました。<br>再生方法の変更は「コントロール」ボタンからいつでも行えます。");
        });
    }

    function showMessage(text) {
        const alertMessage = document.createElement('div');
        alertMessage.classList.add(
            'fixed', 'top-4', 'right-4', 'bg-gradient-to-r',
            'from-gray-800', 'to-gray-600', 'text-white',
            'p-5', 'rounded-lg', 'shadow-xl', 'opacity-90',
            'z-50', 'transform', 'scale-100', 'transition-all',
            'border-2', 'border-indigo-500', 'cursor-pointer'
        );
        alertMessage.style.transition = 'transform 0.3s ease, opacity 0.3s ease';
        alertMessage.innerHTML = `
            <div class="flex items-center justify-between space-x-4">
                <span class="font-semibold">ℹ︎ ${text}</span>
                <button class="text-white hover:text-gray-300 focus:outline-none text-xl font-bold" aria-label="閉じる">&times;</button>
            </div>
        `;
        document.body.appendChild(alertMessage);
        const closeButton = alertMessage.querySelector('button');
        const autoRemoveTimer = setTimeout(() => {
            hideMessage(alertMessage);
        }, 3500);
        closeButton.addEventListener('click', () => {
            clearTimeout(autoRemoveTimer);
            hideMessage(alertMessage);
        });
        let startX = null;
        let currentX = 0;
        let moved = false;
        alertMessage.addEventListener('touchstart', (e) => {
            startX = e.touches[0].clientX;
            moved = false;
            alertMessage.style.transition = 'none';
        });
        alertMessage.addEventListener('touchmove', (e) => {
            if (startX === null) return;
            const touch = e.touches[0];
            const deltaX = touch.clientX - startX;
            if (Math.abs(deltaX) > 5) moved = true;
            currentX = deltaX;
            alertMessage.style.transform = `translateX(${deltaX}px) scale(1)`;
        });
        alertMessage.addEventListener('touchend', () => {
            alertMessage.style.transition = 'transform 0.3s ease, opacity 0.3s ease';
            if (moved && Math.abs(currentX) > 100) {
                alertMessage.style.opacity = '0';
                alertMessage.style.transform = `translateX(${currentX > 0 ? 500 : -500}px) scale(0.95)`;
                setTimeout(() => alertMessage.remove(), 300);
            } else {
                alertMessage.style.transform = 'translateX(0) scale(1)';
            }
            startX = null;
            currentX = 0;
            moved = false;
        });
    }
    function hideMessage(elem) {
        elem.style.transition = 'transform 0.3s ease, opacity 0.3s ease';
        elem.style.opacity = '0';
        elem.style.transform = 'translateX(100%) scale(1.1)';
        setTimeout(() => elem.remove(), 300);
    }
    function showerrorMessage(text) {
        const alertMessage = document.createElement('div');
        alertMessage.classList.add(
            'fixed', 'top-4', 'right-4', 'bg-gradient-to-r', 
            'from-red-600', 'to-red-500', 'text-white', 
            'p-5', 'rounded-lg', 'shadow-xl', 'opacity-90', 
            'z-50', 'transform', 'scale-90', 'transition-transform', 
            'border-2', 'border-red-500'
        );
        alertMessage.innerHTML = `
            <div class="flex items-center justify-between space-x-4">
                <span class="font-semibold">⚠︎ ${text}</span>
                <button class="text-white hover:text-gray-300 focus:outline-none text-xl font-bold" aria-label="閉じる">&times;</button>
            </div>
        `;
        document.body.appendChild(alertMessage);
        const closeButton = alertMessage.querySelector('button');
        const autoRemoveTimer = setTimeout(() => {
            hideMessage(alertMessage);
        }, 3500);
        closeButton.addEventListener('click', () => {
            clearTimeout(autoRemoveTimer);
            hideMessage(alertMessage);
        });
    }
    </script>
</body>
