<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= videoInfo.title %></title>
    <link rel="stylesheet" href="/css/page.css">
    <script src="/js/tailwindcss.js"></script>
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
    <script src="https://code.jquery.com/jquery-3.5.1.js"></script>
    <script src="https://code.jquery.com/ui/1.12.1/jquery-ui.js"></script>
    <script src="/js/tube.js"></script>
    <script src="/js/watch.js"></script>
    <link rel="apple-touch-icon" href="/wkt/back/vi/<%= videoId %>/maxresdefault.jpg">
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const isMobile = window.matchMedia("(max-width: 768px)").matches;

            if (isMobile || localStorage.getItem("sidebarHidden") === "true") {
                document.getElementById("sidebar").classList.add("hidden");
                document.getElementById("videoContainer").classList.add("full");
                document.getElementById("expandSidebar").classList.add("visible");
                document.getElementById("related-sidenone").classList.add("hidden");
            }
        });
    </script>
    <style>
        .comment-box, .related-box {
            transform: translateX(100%);
            transition: transform 0.2s ease-in-out;
        }
        .comment-box.open, .related-box.open {
            transform: translateX(0);
        }
        .main-container {
            display: flex;
            gap: 1rem;
            align-items: flex-start;
            transition: width 0.2s ease-in-out;
        }
        .video-container {
            flex: 1 1 0;
            min-width: 0;
            width: auto;
            transition: width 0.2s ease-in-out;
        }
        .video-container.full {
            width: 100%;
        }
        .sidebar {
            flex: 0 0 18rem;
            width: 18rem;
            transition: transform 0.2s ease-in-out;
        }
        .sidebar.hidden {
            transform: translateX(100%);
        }
        .related-sidenone {
            display: none;
        }
        .related-sidenone.hidden {
            display: block;
        }
        .expand-sidebar-btn {
            position: fixed;
            bottom: 20px;
            right: 10px;
            background: #444;
            color: white;
            padding: 10px 15px;
            border-radius: 5px;
            cursor: pointer;
            display: none;
        }
        .expand-sidebar-btn.visible {
            display: block;
        }
        .toolbar {
            position: fixed;
            top: 0;
            right: -50%;
            width: 50%;
            background: rgba(51, 51, 51, 0.95);
            transition: right 0.2s;
            padding: 20px;
            z-index: 10;
        }
        .toolbar.open { right: 0; }
        .toggle-btn { cursor: pointer; padding: 10px; background: #444; color: white; border: none; border-radius: 5px; }
        .checkbox-container { display: flex; align-items: center; }
        .controlPanel {
            display: none;
        }
        .controlPanel.open { display: block; }
        .tab-button.active {
            background-color: #4a5568;
        }
        .tab-content {
            display: none;
        }
        .tab-content.active {
            display: block;
　　     }
        .loading-indicator {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            display: none;
            z-index: 10;
        }
        .loading-indicator img {
            width: 75px;
            height: 75px;
        }
        .mobile-action-box {
            display: none;
            margin-top: 1rem;
        }
        /* サイドバー非表示時（.full クラスが付与されている状態）にボタンを表示 */
        .video-container.full .mobile-action-box {
            display: block;
        }
    </style>
</head>
<body class="bg-gray-900 text-white">
    <header class="bg-gray-800 p-4 flex justify-between items-center">
        <form action="/wkt/s" method="get" class="w-1/2 relative" id="searchForm">
            <input type="text" name="q" id="searchbox" placeholder="検索" class="searchbox w-full p-2 pr-10 rounded bg-gray-700 text-white">
            <button type="button" id="clearBtn" class="absolute right-2 top-1/2 -translate-y-1/2 flex items-center justify-center h-6 w-6 rounded-full hover:bg-gray-400 text-white text-lg leading-none hidden">
             ×
            </button>
        </form>
        <button id="toggleToolbar" class="toggle-btn w-1/5">ツール</button>
    </header>
  
    <div class="toolbar w-1/2 ml-4" id="toolbar">
        <button id="closeToolbar" class="toggle-btn w-2/3 bg-gray-700 py-2 hover:text-white p-2 rounded mb-2 absolute top-4 right-4">閉じる</button>
        <nav class="mt-12">
            <button onclick="window.location.href='/wkt'" class="w-full bg-gray-700 py-2 hover:text-white p-2 rounded mb-2">ホーム</button>
            <button onclick="window.location.href='/wkt/trend'" class="w-full bg-gray-700 py-2 hover:text-white rounded mb-2">トレンド</button>
            <button onclick="window.location.href='/wkt/cl/fav'" class="w-full bg-gray-700 py-2 hover:text-white rounded mb-2">お気に入り</button>
            <button onclick="window.location.href='/wkt/cl/history'" class="w-full bg-gray-700 py-2 hover:text-white rounded mb-2">再生履歴</button>
            <button onclick="window.open('/wkt/back/vi/<%= videoId %>/maxresdefault.jpg', '_blank');" class="w-full bg-gray-700 py-2 hover:text-white p-2 rounded mb-2">サムネをダウンロード</button>
            <button onclick="window.open('<%- videoData.stream_url %>', '_blank');" class="w-full bg-gray-700 py-2 hover:text-white p-2 rounded mb-2">ストリームURLに移動</button>
            <button onclick="window.open('/other/xerox#/watch/<%= videoId %>', '_blank');" class="w-full bg-gray-700 py-2 hover:text-white p-2 rounded mb-2">XeroxYT-NTで視聴</button>
            <button onclick="window.open('/other/labo5#/watch?v=<%= videoId %>', '_blank');" class="w-full bg-gray-700 py-2 hover:text-white p-2 rounded mb-2">Re: LABO5で視聴</button>
            <button onclick="window.open('/other/player#?v=<%= videoId %>&playlist=<%= videoId %>', '_blank');" class="w-full bg-gray-700 py-2 hover:text-white p-2 rounded mb-2">YouTube 埋め込み再生ツールで視聴</button>
            <button onclick="window.open('/other/player#?v=<%= videoId %>&list=<%= videoInfo.channelId %>', '_blank');" class="w-full bg-gray-700 py-2 hover:text-white p-2 rounded mb-2">YouTube 埋め込み再生ツールでチャンネルの動画を視聴</button>
        </nav>
        <nav class="mt-4">
            <button onclick="window.location.href='/blog/b/wkthelp'" class="w-full bg-gray-700 py-2 hover:text-white p-2 rounded mb-2">ヘルプ</button>
        </nav>
    </div>
    
    <div class="max-w-6xl mx-auto p-4 main-container" id="mainContainer">
        <div class="video-container" id="videoContainer">
        <div class="relative">
        <div class="loading-indicator">
          <img src="https://www.benricho.org/loading_images/img-transparent/89-88.gif" alt="Loading...">
        </div>
          <video id="video" class="w-full h-auto max-h-screen" controls preload="auto" playsinline poster="/wkt/back/vi/<%= videoId %>/maxresdefault.jpg">
              <source id="videoSrc" src="<%- videoData.stream_url %>" type="video/mp4">
          </video>
        <audio id="audio" style="display: none;"></audio>
        <button id="erroreloadButton" class="hidden absolute top-1/2 left-1/2 z-50 -translate-x-1/2 -translate-y-1/2 bg-blue-600 text-white font-semibold py-2 px-4 rounded-xl shadow-lg hover:bg-blue-700 transition">🔄 動画を再読み込み</button>
        <div class="mobile-action-box">
            <button
                class="w-full bg-gray-700 py-2 rounded"
                onclick="document.getElementById('controlPanel').classList.toggle('open')">
                コントロール
            </button>
        </div>
        </div>
            <div class="flex items-start mt-4 p-4 bg-gray-800 rounded gap-3">
              <div class="flex-1 min-w-0">
                <% if (videoInfo.channels.length === 1) { %>
                  <div class="flex items-center gap-3">
                    <a href="/wkt/c/<%= videoInfo.channels[0].id %>" class="flex-shrink-0">
                      <img src="<%= videoInfo.channels[0].icon %>" alt="アイコン" class="w-12 h-12 rounded-full">
                    </a>
                    <div class="min-w-0">
                      <h2 class="text-lg font-bold"><a href="/wkt/c/<%= videoInfo.channels[0].id %>"><%= videoInfo.channels[0].name %></a></h2>
                      <p class="text-sm text-gray-400"><%= videoInfo.channels[0].subsc %></p>
                    </div>
                  </div>
                <% } else { %>
                  <ul class="space-y-3">
                    <% videoInfo.channels.forEach(function(ch) { %>
                      <li class="flex items-center gap-3">
                        <a href="<%= ch.id ? '/wkt/c/' + ch.id : '#' %>" class="flex-shrink-0">
                          <% if (ch.icon) { %>
                            <img src="<%= ch.icon %>" alt="<%= ch.name %>" class="w-12 h-12 rounded-full object-cover">
                          <% } else { %>
                            <div class="w-12 h-12 rounded-full bg-gray-600"></div>
                          <% } %>
                        </a>
                        <div class="min-w-0">
                          <% if (ch.id) { %>
                            <h2 class="text-lg font-bold"><a href="/wkt/c/<%= ch.id %>"><%= ch.name %></a></h2>
                          <% } else { %>
                            <h2 class="text-lg font-bold"><%= ch.name %></h2>
                          <% } %>
                          <% if (ch.subsc) { %><p class="text-sm text-gray-400"><%= ch.subsc %></p><% } %>
                        </div>
                      </li>
                    <% }); %>
                  </ul>
                <% } %>
              </div>
              <button id="favoriteBtn" class="flex-shrink-0 p-2 rounded-full bg-gray-500">
                <img id="favoriteIcon" src="https://wsrv.nl/?url=https://kotonohaworks.com/free-icons/wp-content/uploads/kkrn_icon_hoshi_4.png" alt="お気に入り" class="w-8 h-8">
              </button>
            </div>

    <div class="mt-4 p-4 bg-gray-800 rounded">
      <div class="mt-2 text-gray-400 text-sm">
          <p><%= videoInfo.viewCount %>  ・  <%= videoInfo.likeCount %>いいね  ・  <%= videoInfo.published %></p>
      </div>
    <div class="flex items-center justify-between">
        <h3 class="text-2xl font-bold"> 
          <a href="#mainContainer"><%= videoInfo.title %></a>
        </h3>
        <button class="ml-2 text-blue-500 hover:text-blue-300 text-sm" onclick="toggleDescription(this)">
            折りたたむ
        </button>
    </div>
    <div class="description mt-2">
        <p class="text-base text-gray-300 mt-1"><%- (videoInfo.description || "").replace(/\n/g, "<br>") %></p>
    </div>
    <!-- ダウンロードセクション -->
    <div class="mt-4 border-t border-gray-700 pt-4">
        <button id="downloadBtn" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded transition duration-200 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
            ダウンロード
        </button>
        <div id="downloadOptions" class="hidden mt-3 p-4 bg-gray-700 rounded-lg space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-300 mb-1">タイプ</label>
                    <select id="dlType" class="w-full bg-gray-800 border border-gray-600 rounded p-2 text-white">
                        <option value="both">動画 + 音声 (MP4)</option>
                        <option value="video">動画のみ (MP4/WebM)</option>
                        <option value="audio">音声のみ (MP3/M4A)</option>
                        <option value="image">画像のみ (サムネイル)</option>
                    </select>
                </div>
                <div id="dlQualityContainer">
                    <label class="block text-sm font-medium text-gray-300 mb-1">画質 / 形式</label>
                    <select id="dlQuality" class="w-full bg-gray-800 border border-gray-600 rounded p-2 text-white">
                        <!-- 動的に生成 -->
                    </select>
                </div>
            </div>
            <div class="flex justify-end gap-2">
                <button id="dlCancel" class="bg-gray-600 hover:bg-gray-500 text-white py-1 px-4 rounded">キャンセル</button>
                <button id="dlStart" class="bg-green-600 hover:bg-green-700 text-white py-1 px-4 rounded">保存を開始</button>
            </div>
            <p class="text-xs text-gray-400 mt-2">※Chromebook対応。ダウンロードは新しいタブで開かれます。</p>
        </div>
    </div>
   </div>
              
            <div class="mt-4 p-4 bg-gray-800 rounded">
                <h3 class="text-lg font-bold">コメント</h3>
                <div class="mt-2 space-y-2">
                <div id="commentError2" class="text-red-500 hidden"></div>
                <div id="commentsList2" class="mt-2 space-y-2">
                   <p>コメントを取得中...</p>
                </div>
                </div>

               <button id="retryButton" class="w-full bg-gray-700 py-2 rounded mt-2 hidden">再取得</button>
            </div>
            <div class="related-sidenone mt-4 p-4 bg-gray-800 rounded" id="related-sidenone">
            <h3 class="text-lg font-bold">関連動画</h3><br>
<% if (videoInfo.watch_next_feed && videoInfo.watch_next_feed.length > 0) { %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
            <% videoInfo.watch_next_feed.forEach(video => { %>
              <% if (video.type.endsWith("Video")) { %>
                <div class="result-item bg-gray-800 p-4 rounded-lg shadow hover:bg-gray-700 transition duration-200">
                    <a href="/wkt/watch/<%= video.id %>" class="block relative group">
                        <img loading="lazy" src="/wkt/back/vi/<%= video.id %>/mqdefault.jpg" alt="<%= video.title?.text || '動画' %>" class="w-full h-auto rounded aspect-video object-cover">
                        <% if (video.duration?.text) { %>
                            <span class="absolute bottom-1 right-1 bg-black bg-opacity-80 text-white text-xs px-1.5 py-0.5 rounded font-medium"><%= video.duration.text %></span>
                        <% } %>
                        <div class="absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-10 transition rounded"></div>
                    </a>
                    <div class="mt-3 flex items-start space-x-3">
                        <a href="<%= (video.author?.id && video.author.id !== 'N/A') ? '/wkt/c/' + video.author.id : '/wkt/watch/' + video.id %>" class="flex-shrink-0">
                            <% if (video.author?.thumbnails?.length) { %>
                            <% if (video.author.id === 'N/A') { %>
                            <img src="<%= video.author.thumbnails[0].url %>" alt="<%= video.author?.name || '' %>" class="w-9 h-9 rounded-full object-cover bg-gray-600 border border-gray-700">
                            <% } else { %>
                            <img src="/wkt/back/yt3<%- (new URL(video.author.thumbnails[0].url)).pathname %>" alt="<%= video.author?.name || '' %>" class="w-9 h-9 rounded-full object-cover bg-gray-600 border border-gray-700">
                            <% } %>
                            <% } else { %>
                            <div class="w-9 h-9 rounded-full bg-gray-600 border border-gray-700"></div>
                            <% } %>
                        </a>
                        <div class="flex-1 min-w-0">
                            <a href="/wkt/watch/<%= video.id %>">
                                <p class="text-white font-bold text-sm leading-snug line-clamp-2 mb-1 hover:text-blue-400 transition"><%= video.title?.text || '' %></p>
                            </a>
                            <a href="<%= (video.author?.id && video.author.id !== 'N/A') ? '/wkt/c/' + video.author.id : '/wkt/watch/' + video.id %>" class="text-gray-400 text-xs hover:text-white transition mb-0.5 block truncate"><%= video.author?.name || '' %></a>
                            <p class="text-gray-500 text-xs"><%= video.short_view_count?.text || video.view_count?.text || "" %><% if (video.published?.text) { %> • <%= video.published.text %><% } %></p>
                        </div>
                    </div>
                </div>
              <% } else if (video.type.endsWith("Playlist")) { %>
                <div class="result-item bg-gray-800 p-4 rounded-lg shadow hover:bg-gray-700 transition duration-200">
                    <a href="/wkt/watch/<%= video.id %>" class="block relative group">
                        <img loading="lazy" src="/wkt/back/vi/<%= video.id %>/mqdefault.jpg" alt="<%= video.title?.text || '再生リスト' %>" class="w-full h-auto rounded aspect-video object-cover">
                        <div class="absolute inset-0 bg-black bg-opacity-40 flex items-center justify-center rounded">
                            <div class="text-center">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mx-auto mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                                </svg>
                                <span class="text-sm font-bold"><%= video.video_count?.text || '再生リスト' %></span>
                            </div>
                        </div>
                    </a>
                    <div class="mt-3">
                        <a href="/wkt/watch/<%= video.id %>">
                            <p class="text-white font-bold text-sm leading-snug line-clamp-2 hover:text-blue-400 transition"><%= video.title?.text || '' %></p>
                        </a>
                        <p class="text-gray-400 text-xs mt-1"><%= video.author?.name || '' %></p>
                    </div>
                </div>
              <% } %>
            <% }); %>
        </div>
<% } else { %>
    <p class="text-gray-400 text-center py-8">関連動画が見つかりませんでした</p>
<% } %>
            </div>
        </div>

        <div class="sidebar" id="sidebar">
            <div class="bg-gray-800 p-4 rounded mb-4">
                <h3 class="text-lg font-bold mb-4">コントロール</h3>
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-400 mb-1">画質</label>
                        <select id="qualitySelect" class="w-full bg-gray-700 border-none rounded p-2 text-white">
                            <option value="<%- videoData.stream_url %>" data-is-auto="true">統合ストリーム (標準)</option>
                            <% if (videoData.streamUrls && videoData.streamUrls.length > 0) { %>
                                <% videoData.streamUrls.forEach(function(stream) { %>
                                    <option value="<%= stream.url %>" data-container="<%= stream.container %>">
                                        <%= stream.resolution %> (<%= stream.container %>) <%= stream.fps ? stream.fps + 'fps' : '' %>
                                    </option>
                                <% }); %>
                            <% } %>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-400 mb-1">音質</label>
                        <select id="audioSelect" class="w-full bg-gray-700 border-none rounded p-2 text-white">
                            <% if (videoData.audioUrls && videoData.audioUrls.length > 0) { %>
                                <% videoData.audioUrls.forEach(function(audio) { %>
                                    <option value="<%= audio.url %>" <%= audio.url === videoData.audioUrl ? 'selected' : '' %>>
                                        <%= audio.label %> (<%= audio.container %>)
                                    </option>
                                <% }); %>
                            <% } else { %>
                                <option value="<%- videoData.audioUrl %>">デフォルト音声</option>
                            <% } %>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-400 mb-1">サーバー</label>
                        <select id="serverSelect" class="w-full bg-gray-700 border-none rounded p-2 text-white">
                            <option value="invidious" <%= baseUrl === 'invidious' ? 'selected' : '' %>>Invidious (標準)</option>
                            <option value="acethinker" <%= baseUrl === 'acethinker' ? 'selected' : '' %>>AceThinker</option>
                            <option value="siawaseok" <%= baseUrl === 'siawaseok' ? 'selected' : '' %>>SiawaseOk</option>
                            <option value="yudlp" <%= baseUrl === 'yudlp' ? 'selected' : '' %>>YuDLP</option>
                            <option value="ytdlpinstance-vercel" <%= baseUrl === 'ytdlpinstance-vercel' ? 'selected' : '' %>>KatuoTube</option>
                            <option value="senninytdlp" <%= baseUrl === 'senninytdlp' ? 'selected' : '' %>>SenninTube</option>
                            <option value="min-tube2-api" <%= baseUrl === 'min-tube2-api' ? 'selected' : '' %>>MinTube2</option>
                            <option value="xeroxyt-nt-apiv1" <%= baseUrl === 'xeroxyt-nt-apiv1' ? 'selected' : '' %>>XeroxYT-NT</option>
                            <option value="simple-yt-stream" <%= baseUrl === 'simple-yt-stream' ? 'selected' : '' %>>Wista Stream</option>
                            <option value="freemake" <%= baseUrl === 'freemake' ? 'selected' : '' %>>Freemake</option>
                        </select>
                    </div>
                    <div class="flex items-center gap-2">
                        <input type="checkbox" id="hdToggle" class="rounded bg-gray-700 border-none text-blue-500">
                        <label for="hdToggle" class="text-sm font-medium text-gray-400">高画質モード (WebM)</label>
                    </div>
                    <div class="flex gap-2">
                        <button id="changeServer" class="flex-1 bg-blue-600 hover:bg-blue-700 py-2 rounded text-sm font-bold">サーバー変更</button>
                        <button id="qualityReset" class="bg-gray-700 hover:bg-gray-600 p-2 rounded">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                            </svg>
                        </button>
                    </div>
                </div>
            </div>

            <div class="bg-gray-800 p-4 rounded">
                <h3 class="text-lg font-bold mb-4">再生設定</h3>
                <div class="space-y-3">
                    <div class="flex items-center gap-2">
                        <input type="radio" name="playbackMode" value="normal" id="modeNormal" class="bg-gray-700 border-none text-blue-500">
                        <label for="modeNormal" class="text-sm text-gray-300">Normal (標準)</label>
                    </div>
                    <div class="flex items-center gap-2">
                        <input type="radio" name="playbackMode" value="edu" id="modeEdu" class="bg-gray-700 border-none text-blue-500">
                        <label for="modeEdu" class="text-sm text-gray-300">Education (埋め込み)</label>
                    </div>
                    <div class="flex items-center gap-2">
                        <input type="radio" name="playbackMode" value="nocookie" id="modeNoCookie" class="bg-gray-700 border-none text-blue-500">
                        <label for="modeNoCookie" class="text-sm text-gray-300">NoCookie (プライバシー)</label>
                    </div>
                    <button id="saveSettings" class="w-full bg-gray-700 hover:bg-gray-600 py-2 rounded text-sm font-bold mt-2">設定を保存</button>
                </div>
            </div>
        </div>
    </div>

    <button id="expandSidebar" class="expand-sidebar-btn">サイドバーを表示</button>

    <div id="messageBox" class="fixed bottom-4 left-4 z-50 transform -translate-x-full transition-transform duration-300 ease-in-out bg-gray-800 text-white p-4 rounded shadow-lg border-l-4 border-blue-500 hidden">
        <p id="messageText"></p>
    </div>

    <div id="errorMessage" class="fixed top-4 left-1/2 -translate-x-1/2 z-50 bg-red-600 text-white p-4 rounded shadow-xl hidden">
        <p id="errorText"></p>
    </div>

    <script>
    const video = document.getElementById('video');
    const audio = document.getElementById('audio');
    const videoSrc = document.getElementById('videoSrc');

    function showMessage(text) {
        const box = document.getElementById('messageBox');
        const msg = document.getElementById('messageText');
        msg.innerHTML = text;
        box.classList.remove('hidden');
        setTimeout(() => box.classList.remove('-translate-x-full'), 10);
        setTimeout(() => {
            box.classList.add('-translate-x-full');
            setTimeout(() => box.classList.add('hidden'), 300);
        }, 5000);
    }

    function showerrorMessage(text) {
        const box = document.getElementById('errorMessage');
        const msg = document.getElementById('errorText');
        msg.textContent = text;
        box.classList.remove('hidden');
        setTimeout(() => box.classList.add('hidden'), 5000);
    }

    $(document).ready(function() {
        // コメント取得
        const videoId = "<%= videoId %>";
        $.get(`/wkt/back/comment/${videoId}`, function(data) {
            $('#commentsList2').html(data);
        }).fail(function() {
            $('#commentsList2').html('<p class="text-red-500">コメントの取得に失敗しました</p>');
            $('#retryButton').removeClass('hidden');
        });

        $('#retryButton').click(function() {
            $(this).addClass('hidden');
            $('#commentsList2').html('<p>コメントを取得中...</p>');
            $.get(`/wkt/back/comment/${videoId}`, function(data) {
                $('#commentsList2').html(data);
            }).fail(function() {
                $('#commentsList2').html('<p class="text-red-500">コメントの取得に失敗しました</p>');
                $('#retryButton').removeClass('hidden');
            });
        });

        // 再生設定の初期化
        const cookies = document.cookie.split(';').reduce((res, c) => {
            const [key, val] = c.trim().split('=');
            res[key] = val;
            return res;
        }, {});
        const mode = cookies.playbackMode || 'normal';
        $(`#mode${mode.charAt(0).toUpperCase() + mode.slice(1)}`).prop('checked', true);

        // サイドバー開閉
        $('#expandSidebar').click(function() {
            $('#sidebar').removeClass('hidden');
            $('#videoContainer').removeClass('full');
            $(this).removeClass('visible');
            $('#related-sidenone').removeClass('hidden');
            localStorage.setItem("sidebarHidden", "false");
        });

        // 動画エラー時の再読み込み
        video.addEventListener('error', function() {
            $('#erroreloadButton').removeClass('hidden');
        });
        $('#erroreloadButton').click(function() {
            const currentTime = video.currentTime;
            video.load();
            video.currentTime = currentTime;
            $(this).addClass('hidden');
            video.play();
        });

        // 同期再生
        video.addEventListener('play', () => {
            if (audio.src && audio.src !== window.location.href) {
                audio.play();
            }
        });
        video.addEventListener('pause', () => {
            audio.pause();
        });
        video.addEventListener('seeking', () => {
            audio.pause();
            audio.currentTime = 0;
        });
        video.addEventListener('seeked', () => {
            if (audio.src && audio.src !== window.location.href) {
                audio.currentTime = video.currentTime;
            }
        });
        video.addEventListener('timeupdate', () => {
            if (audio.src && audio.src !== window.location.href) {
                if (Math.abs(video.currentTime - audio.currentTime) > 0.4) {
                    audio.currentTime = video.currentTime + 0.1;
                }
            }
        });

        // 画質変更
        $('#qualitySelect').change(function() {
            const selectedOption = $(this).find(':selected');
            const container = selectedOption.attr('data-container') || 'mp4';
            const isAuto = selectedOption.attr('data-is-auto') === 'true';
            const newUrl = selectedOption.val();

            video.pause();
            audio.pause();
            const currentTime = video.currentTime;

            if (container === 'm3u8') {
                videoSrc.type = "application/x-mpegURL";
            } else {
                videoSrc.type = "video/" + container;
            }
            videoSrc.src = newUrl;

            if (isAuto || newUrl.includes("manifest") || newUrl.includes(".m3u8")) {
                audio.src = "";
            } else {
                audio.src = $('#audioSelect').val() || "<%- videoData.audioUrl || '' %>";
            }

            video.load();
            if (audio.src && audio.src !== window.location.href) {
                audio.load();
                audio.currentTime = currentTime;
            }
            video.currentTime = currentTime;
            video.play().catch(e => console.error(e));
        });

        // 音質変更
        $('#audioSelect').change(function() {
            const selectedQuality = $('#qualitySelect').find(':selected');
            const isAuto = selectedQuality.attr('data-is-auto') === 'true';
            const currentVideoUrl = selectedQuality.val();
            const newAudioUrl = $(this).val();

            if (isAuto || currentVideoUrl.includes("manifest") || currentVideoUrl.includes(".m3u8")) {
                return;
            }

            const currentTime = video.currentTime;
            const wasPlaying = !video.paused;

            video.pause();
            audio.pause();
            audio.src = newAudioUrl;
            audio.load();
            audio.currentTime = currentTime;
            if (wasPlaying) {
                video.play().catch(e => console.error(e));
            }
        });

        // 画質リセット
        $('#qualityReset').click(function() {
            video.pause();
            audio.pause();
            const currentTime = video.currentTime;
            videoSrc.type = "video/mp4";
            videoSrc.src = "<%- videoData.stream_url %>";
            audio.src = "";
            $('#qualitySelect').prop('selectedIndex', 0);
            video.load();
            video.currentTime = currentTime;
            video.play().catch(e => console.error(e));
        });

        // サーバー変更
        $('#changeServer').click(function() {
            const server = $('#serverSelect').val();
            showMessage(`サーバーを「${server}」に移動します☑️`);
            window.location.href = `/wkt/watch/<%= videoId %>?server=${server}`;
        });

        // 設定保存
        $('#saveSettings').click(function() {
            const mode = $('input[name="playbackMode"]:checked').val();
            document.cookie = `playbackMode=${mode}; path=/; max-age=31536000`;
            showMessage(`再生方法を${mode}に変更します☑️`);
            window.location.href = `/wkt/redirect/mode/<%= videoId %>?mode=${mode}`;
        });

        // ツールバー
        $('#toggleToolbar').click(() => $('#toolbar').addClass('open'));
        $('#closeToolbar').click(() => $('#toolbar').removeClass('open'));

        // 高画質トグル
        $('#hdToggle').change(function() {
            const currentTime = video.currentTime;
            const wasPlaying = !video.paused;

            if (this.checked) {
                videoSrc.type = "video/webm";
                videoSrc.src = "<%- videoData.highstreamUrl %>";
                if ("<%- videoData.highstreamUrl %>".startsWith("https://manifest.googlevideo.com/")) {
                    audio.src = "";
                } else {
                    audio.src = "<%- videoData.audioUrl || '' %>";
                }
                video.load();
                if (audio.src && audio.src !== window.location.href) {
                    audio.load();
                    audio.currentTime = currentTime;
                }
            } else {
                videoSrc.type = "video/mp4";
                videoSrc.src = "<%- videoData.stream_url %>";
                audio.pause();
                audio.src = '';
                video.load();
            }
            video.currentTime = currentTime;
            if (wasPlaying) {
                video.play().catch(error => console.error("動画の再生エラー:", error));
            }
        });

        // 概要欄トグル
        window.toggleDescription = function(button) {
            const description = button.closest('div').nextElementSibling;
            if (description.classList.contains('hidden')) {
                description.classList.remove('hidden');
                button.textContent = '折りたたむ';
            } else {
                description.classList.add('hidden');
                button.textContent = '表示する';
            }
        };

        // お気に入り
        const videoId = "<%= videoId %>";
        const channelId = "<%= videoInfo.channelId %>";
        const channelName = "<%= videoInfo.channelName %>";
        const videoTitle = "<%= videoInfo.title %>";

        function getFavorites() {
            return JSON.parse(localStorage.getItem("wakametubefavorites") || "[]");
        }

        function checkFav() {
            const favorites = getFavorites();
            const isFavorited = favorites.some(f => f.videoId === videoId);
            $('#favoriteIcon').attr('src', isFavorited ? "https://wsrv.nl/?url=https://kotonohaworks.com/free-icons/wp-content/uploads/kkrn_icon_hoshi_1.png" : "https://wsrv.nl/?url=https://kotonohaworks.com/free-icons/wp-content/uploads/kkrn_icon_hoshi_4.png");
        }

        $('#favoriteBtn').click(function() {
            let favorites = getFavorites();
            const index = favorites.findIndex(f => f.videoId === videoId);
            if (index !== -1) {
                favorites.splice(index, 1);
                showMessage(`${videoTitle}をお気に入りから解除しました`);
            } else {
                favorites.push({ videoId, channelId, channelName, videoTitle });
                showMessage(`${videoTitle}をお気に入りに追加しました`);
            }
            localStorage.setItem("wakametubefavorites", JSON.stringify(favorites));
            checkFav();
        });

        checkFav();

        // 履歴保存
        function saveToHistory() {
            let history = JSON.parse(localStorage.getItem("wakametubehistory") || "[]");
            history = history.filter(h => h.videoId !== videoId);
            history.unshift({ videoId, channelId, channelName, videoTitle });
            if (history.length > 50) history.pop();
            localStorage.setItem("wakametubehistory", JSON.stringify(history));
        }
        saveToHistory();

        // ダウンロード機能
        const videoData = <%- JSON.stringify(videoData) %>;
        $('#downloadBtn').click(function() {
            $('#downloadOptions').toggleClass('hidden');
            updateDownloadQualities();
        });
        $('#dlCancel').click(function() {
            $('#downloadOptions').addClass('hidden');
        });
        $('#dlType').change(updateDownloadQualities);

        function updateDownloadQualities() {
            const type = $('#dlType').val();
            const $select = $('#dlQuality');
            $select.empty();
            if (type === 'both') {
                if (videoData.stream_url) $select.append(`<option value="${videoData.stream_url}">標準画質 (統合MP4)</option>`);
                if (videoData.streamUrls) {
                    videoData.streamUrls.forEach(s => {
                        if (s.container === 'mp4' && !s.url.includes('manifest')) {
                            $select.append(`<option value="${s.url}">${s.resolution} (${s.container})</option>`);
                        }
                    });
                }
            } else if (type === 'video') {
                if (videoData.streamUrls) {
                    videoData.streamUrls.forEach(s => {
                        $select.append(`<option value="${s.url}">${s.resolution} (${s.container})</option>`);
                    });
                }
                if (videoData.highstreamUrl) $select.append(`<option value="${videoData.highstreamUrl}">高画質 WebM (映像のみ)</option>`);
            } else if (type === 'audio') {
                if (videoData.audioUrls && videoData.audioUrls.length > 0) {
                    videoData.audioUrls.forEach(a => {
                        $select.append(`<option value="${a.url}">${a.label || '音声'} (${a.container || 'm4a'})</option>`);
                    });
                } else if (videoData.audioUrl) {
                    $select.append(`<option value="${videoData.audioUrl}">標準音声 (m4a)</option>`);
                }
                $select.append(`<option value="https://www.youtube.com/watch?v=${videoId}">YouTubeで開く (外部変換用)</option>`);
            } else if (type === 'image') {
                $select.append(`<option value="/wkt/back/vi/${videoId}/maxresdefault.jpg">最大サイズ (JPG)</option>`);
                $select.append(`<option value="/wkt/back/vi/${videoId}/hqdefault.jpg">高画質 (JPG)</option>`);
                $select.append(`<option value="/wkt/back/vi/${videoId}/mqdefault.jpg">中画質 (JPG)</option>`);
            }
            if ($select.children().length === 0) $select.append('<option value="">利用可能な形式がありません</option>');
        }

        $('#dlStart').click(function() {
            const url = $('#dlQuality').val();
            if (!url) return;
            if (confirm('ダウンロードを開始しますか？\n※著作権に注意し、私的利用の範囲内でご利用ください。')) {
                window.open(url, '_blank');
                $('#downloadOptions').addClass('hidden');
                showMessage('ダウンロードを開始しました。新しいタブを確認してください。');
            }
        });
    });

    // ショートカット
    document.addEventListener('keydown', function(event) {
        if (['INPUT', 'TEXTAREA'].includes(document.activeElement.tagName)) return;
        if (event.code === 'Space') {
            event.preventDefault();
            video.paused ? video.play() : video.pause();
        }
        if (event.key.toLowerCase() === 'f') {
            event.preventDefault();
            if (!document.fullscreenElement) {
                video.requestFullscreen?.() || video.mozRequestFullScreen?.() || video.webkitRequestFullscreen?.() || video.msRequestFullscreen?.();
            } else {
                document.exitFullscreen?.() || document.mozCancelFullScreen?.() || document.webkitExitFullscreen?.() || document.msExitFullscreen?.();
            }
        }
        if (event.key === 'ArrowRight') video.currentTime += 10;
        if (event.key === 'ArrowLeft') video.currentTime -= 10;
    });

    // WakeLock
    let wakeLock = null;
    video.addEventListener('play', async () => {
        try {
            if (!wakeLock) wakeLock = await navigator.wakeLock.request('screen');
        } catch (err) {}
    });
    const releaseWakeLock = () => {
        if (wakeLock) {
            wakeLock.release().then(() => wakeLock = null);
        }
    };
    video.addEventListener('pause', releaseWakeLock);
    video.addEventListener('ended', releaseWakeLock);
    </script>
</body>
</html>
