<!DOCTYPE html>
<html lang="ja" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>わかめ🎶 - <%= query %></title>
    <script src="/js/tailwindcss.js"></script>
    <style>
        /* アーティスト選択 UI */
        #artistSelector {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(17, 24, 39, 0.98);
            z-index: 10000;
            padding: 40px 20px;
            overflow-y: auto;
        }
        #artistSelector.active { display: block; }
        .artist-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
            gap: 20px;
            max-width: 800px;
            margin: 30px auto;
        }
        .artist-item {
            background: #1f2937;
            border-radius: 12px;
            padding: 15px;
            text-align: center;
            cursor: pointer;
            transition: transform 0.2s, border-color 0.2s;
            border: 2px solid transparent;
        }
        .artist-item:hover { transform: scale(1.05); }
        .artist-item.selected { border-color: #3b82f6; background: #374151; }
        .artist-item img {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            margin: 0 auto 10px;
            object-fit: cover;
        }
    </style>
</head>
<body class="bg-gray-900 text-white flex flex-col items-center">

<!-- アーティスト選択オーバーレイ -->
<div id="artistSelector">
    <div class="max-w-2xl mx-auto text-center">
        <h1 class="text-3xl font-bold mb-4">好きなアーティストを3つ選んでください</h1>
        <p class="text-gray-400 mb-8">あなたにぴったりの音楽をおすすめします。</p>
        <div class="artist-grid" id="artistGrid">
            <!-- JSで動的に追加 -->
        </div>
        <button id="finishSelection" class="mt-8 px-10 py-3 bg-blue-600 hover:bg-blue-700 rounded-full font-bold text-lg transition-colors opacity-50 cursor-not-allowed" disabled>
            開始する
        </button>
    </div>
</div>

<header class="p-4 w-full flex items-center gap-3 bg-gray-800 shadow-lg">
    <button onclick="window.location.href='/wkt'" class="p-2 bg-gray-700 hover:bg-gray-600 rounded transition flex-shrink-0" title="ホームへ戻る">
        🏠
    </button>

    <form action="/wakams/s" method="get" class="flex gap-2 w-full max-w-lg">
        <input type="text" name="q" id="musicSearch" placeholder="曲を探す" required value="<%= query %>" class="p-2 rounded bg-gray-700 text-white w-full">
        <button type="submit" class="p-2 bg-blue-600 rounded hover:bg-blue-500 transition">🔍</button>
    </form>

    <button onclick="window.location.href='/wakams/f'" class="p-2 bg-yellow-500 rounded hover:bg-yellow-400 transition whitespace-nowrap">⭐ お気に入り</button>
</header>

<main class="p-4 w-full max-w-2xl">
    <!-- おすすめセクション -->
    <div id="recommendationSection" class="mb-8 hidden">
        <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
            <span class="text-green-400">✨</span> あなたへのおすすめ
        </h2>
        <div id="recommendationList" class="grid gap-4">
            <!-- 動的に追加 -->
        </div>
    </div>

    <% if (tracks && tracks.length > 0) { %>
        <div class="grid gap-4" id="trackList">
            <% tracks.forEach(track => { %>
                <div class="flex items-center gap-4 p-4 border border-gray-700 bg-gray-800 hover:bg-gray-700 transition rounded-lg shadow-md track-item" data-id="<%= track.id %>" data-title="<%= track.title %>">
                    <img src="<%= track.artwork_url %>" alt="Artwork" class="w-20 h-20 rounded shadow-md">
                    <div class="flex-1">
                        <p class="font-bold text-lg"><%= track.title %></p>
                        <p class="text-sm text-gray-400">by <%= track.username %></p>
                    </div>
                    <div class="flex gap-2">
                        <button class="play-btn p-3 bg-gray-500 hover:bg-gray-400 rounded-lg transition text-white text-xl" data-track-id="<%= track.id %>"><img src="https://cdn.glitch.global/44a02c72-aa32-4a7b-bb98-801035391fbc/IMG_3047.png?v=1743129550178" class="w-6 h-6"></button>
                        <button class="favorite-btn p-2 rounded transition text-white" data-id="<%= track.id %>" onclick="toggleFavorite('<%= track.artwork_url %>', '<%= track.title %>', '<%= track.id %>')">
                            ❤️
                        </button>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } else { %>
      <% if (query && query.length > 0) { %>
        <p class="text-center text-gray-400">曲が見つかりません。</p>
      <% } else { %>
        <p class="text-center text-gray-400" id="initialMessage">まずは検索してみましょう。</p>
      <% } %>
    <% } %>
</main>
      
<div id="player-container" class="fixed bottom-0 left-0 w-full bg-gray-800 p-4 hidden flex flex-col items-center gap-2 shadow-lg z-50">
    <div class="w-full flex justify-between items-center px-4">
        <span id="nowPlayingTitle" class="text-sm font-medium truncate max-w-[70%]">再生中...</span>
        <button id="closePlayer" class="text-gray-400 hover:text-white">✕</button>
    </div>
    <iframe id="player" class="w-full h-[120px]" frameborder="no" scrolling="no" allow="autoplay"></iframe>
</div>

<footer class="p-4 text-center text-gray-500">🎵 Wakamc Music Player 🎵</footer>

<script src="https://w.soundcloud.com/player/api.js"></script>
<script>
    // --- アーティスト選択 & パーソナライズ ---
    const artists = [
        { name: 'YOASOBI', img: 'https://www.yoasobi-music.jp/img/profile.jpg' },
        { name: '米津玄師', img: 'https://reissuerecords.net/common/img/profile_photo.jpg' },
        { name: 'Official髭男dism', img: 'https://higedan.com/wp-content/uploads/2021/02/artist_photo_2021.jpg' },
        { name: 'Ado', img: 'https://www.universal-music.co.jp/ado/wp-content/uploads/sites/4243/2022/01/ado_profile.jpg' },
        { name: 'Vaundy', img: 'https://vaundy.jp/img/profile.jpg' },
        { name: 'Mrs. GREEN APPLE', img: 'https://mrsgreenapple.com/img/profile.jpg' },
        { name: 'King Gnu', img: 'https://kinggnu.jp/img/profile.jpg' },
        { name: '優里', img: 'https://www.yuuri-music.com/img/profile.jpg' }
    ];

    const selectedArtists = new Set();
    const artistSelector = document.getElementById('artistSelector');
    const artistGrid = document.getElementById('artistGrid');
    const finishBtn = document.getElementById('finishSelection');

    // 初期化
    window.addEventListener('load', () => {
        if (!localStorage.getItem('music_artists_selected')) {
            showArtistSelector();
        } else {
            loadRecommendations();
        }
    });

    function showArtistSelector() {
        artistSelector.classList.add('active');
        artistGrid.innerHTML = '';
        artists.forEach(artist => {
            const div = document.createElement('div');
            div.className = 'artist-item';
            div.innerHTML = `
                <img src="${artist.img}" onerror="this.src='https://wsrv.nl/?url=https://icooon-mono.com/i/icon_10173/icon_101730_256.png'">
                <p class="font-bold">${artist.name}</p>
            `;
            div.onclick = () => {
                if (selectedArtists.has(artist.name)) {
                    selectedArtists.delete(artist.name);
                    div.classList.remove('selected');
                } else {
                    selectedArtists.add(artist.name);
                    div.classList.add('selected');
                }
                finishBtn.disabled = selectedArtists.size < 3;
                finishBtn.style.opacity = selectedArtists.size >= 3 ? '1' : '0.5';
                finishBtn.classList.toggle('cursor-not-allowed', selectedArtists.size < 3);
            };
            artistGrid.appendChild(div);
        });
    }

    finishBtn.onclick = () => {
        localStorage.setItem('music_artists_selected', JSON.stringify(Array.from(selectedArtists)));
        artistSelector.classList.remove('active');
        loadRecommendations();
        showMessage('設定が完了しました！おすすめを表示します。');
    };

    async function loadRecommendations() {
        const selected = JSON.parse(localStorage.getItem('music_artists_selected') || '[]');
        if (selected.length === 0) return;

        const recSection = document.getElementById('recommendationSection');
        const recList = document.getElementById('recommendationList');
        const initialMsg = document.getElementById('initialMessage');
        
        recSection.classList.remove('hidden');
        if (initialMsg) initialMsg.classList.add('hidden');
        recList.innerHTML = '<p class="text-gray-400">読み込み中...</p>';

        try {
            // アーティスト名で検索
            const randomArtist = selected[Math.floor(Math.random() * selected.length)];
            const res = await fetch(`/wakams/s?q=${encodeURIComponent(randomArtist)}&ajax=true`);
            // 注: サーバー側がAJAX対応していない場合を考慮し、通常はfetch後にパースする
            // ここでは簡易的に、現在のリストからランダムに表示するか、再検索を促す
            
            // 実際には /wakams/s にリクエストを送って結果を取得する
            const response = await fetch(`/wakams/s?q=${encodeURIComponent(randomArtist)}`);
            const html = await response.text();
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');
            const tracks = doc.querySelectorAll('.play-btn');
            
            recList.innerHTML = '';
            let count = 0;
            tracks.forEach(btn => {
                if (count >= 3) return;
                const id = btn.getAttribute('data-track-id');
                const parent = btn.closest('div').parentElement;
                const title = parent.querySelector('.font-bold').textContent;
                const img = parent.querySelector('img').src;
                const user = parent.querySelector('.text-gray-400').textContent;

                const item = document.createElement('div');
                item.className = 'flex items-center gap-4 p-3 bg-gray-800 border border-blue-900/30 rounded-lg hover:bg-gray-700 transition cursor-pointer';
                item.onclick = () => playTrack(id, title);
                item.innerHTML = `
                    <img src="${img}" class="w-14 h-14 rounded">
                    <div class="flex-1 overflow-hidden">
                        <p class="font-bold truncate">${title}</p>
                        <p class="text-xs text-gray-400 truncate">${user}</p>
                    </div>
                    <div class="text-blue-400">▶</div>
                `;
                recList.appendChild(item);
                count++;
            });
        } catch (e) {
            recList.innerHTML = '<p class="text-gray-500 text-sm">おすすめを取得できませんでした。</p>';
        }
    }

    // --- プレイヤー & 自動再生 ---
    let widget = null;
    let currentPlaylist = [];
    let currentTrackIndex = -1;

    document.querySelectorAll('.play-btn').forEach(btn => {
        btn.addEventListener('click', function () {
            const trackId = this.getAttribute('data-track-id');
            const title = this.closest('.track-item').querySelector('.font-bold').textContent;
            
            // プレイリストの構築
            const allTracks = Array.from(document.querySelectorAll('.track-item'));
            currentPlaylist = allTracks.map(el => ({
                id: el.getAttribute('data-id'),
                title: el.getAttribute('data-title')
            }));
            currentTrackIndex = currentPlaylist.findIndex(t => t.id === trackId);
            
            playTrack(trackId, title);
        });
    });

    function playTrack(trackId, title) {
        const playerContainer = document.getElementById('player-container');
        const player = document.getElementById('player');
        const titleEl = document.getElementById('nowPlayingTitle');
        
        titleEl.textContent = title || '再生中...';
        player.src = `https://w.soundcloud.com/player/?url=https%3A//api.soundcloud.com/tracks/${trackId}&color=%233b82f6&auto_play=true&hide_related=false&show_comments=true&show_user=true&show_reposts=false&show_teaser=true`;
        playerContainer.classList.remove('hidden');

        // SoundCloud Widget API の初期化
        if (!widget) {
            widget = SC.Widget(player);
            widget.bind(SC.Widget.Events.FINISH, () => {
                playNext();
            });
        }
    }

    async function playNext() {
        if (currentTrackIndex !== -1 && currentTrackIndex < currentPlaylist.length - 1) {
            // リスト内の次の曲
            currentTrackIndex++;
            const next = currentPlaylist[currentTrackIndex];
            playTrack(next.id, next.title);
        } else {
            // リストが終わった、または検索結果がない場合、自動でおすすめを取得して再生
            showMessage('次の曲を自動取得しています...');
            const selected = JSON.parse(localStorage.getItem('music_artists_selected') || '["J-POP"]');
            const randomQuery = selected[Math.floor(Math.random() * selected.length)];
            
            try {
                const response = await fetch(`/wakams/s?q=${encodeURIComponent(randomQuery)}`);
                const html = await response.text();
                const parser = new DOMParser();
                const doc = parser.parseFromString(html, 'text/html');
                const tracks = doc.querySelectorAll('.play-btn');
                
                if (tracks.length > 0) {
                    const randomIdx = Math.floor(Math.random() * tracks.length);
                    const btn = tracks[randomIdx];
                    const id = btn.getAttribute('data-track-id');
                    const title = btn.closest('div').parentElement.querySelector('.font-bold').textContent;
                    playTrack(id, title);
                }
            } catch (e) {
                console.error('Auto-play error:', e);
            }
        }
    }

    document.getElementById('closePlayer').onclick = () => {
        document.getElementById('player-container').classList.add('hidden');
        if (widget) widget.pause();
    };

    // --- 既存のロジック ---
    function toggleFavorite(artwork_url, title, id) {
        let favorites = JSON.parse(localStorage.getItem('favorites')) || [];
        const index = favorites.findIndex(track => track.id === id);

        if (index === -1) {
            favorites.push({ artwork_url, title, id });
            showMessage(`「${title}」をお気に入りに追加しました！`);
        } else {
            favorites.splice(index, 1);
            showMessage(`「${title}」のお気に入りを解除しました！`);
        }

        localStorage.setItem('favorites', JSON.stringify(favorites));
        updateFavoriteButtons();
    }

    function updateFavoriteButtons() {
        const favorites = JSON.parse(localStorage.getItem('favorites')) || [];
        document.querySelectorAll('.favorite-btn').forEach(btn => {
            const trackId = btn.getAttribute('data-id');
            if (favorites.some(track => track.id === trackId)) {
                btn.classList.add('text-red-500');
            } else {
                btn.classList.remove('text-red-500');
            }
        });
    }

    updateFavoriteButtons();
  
    function showMessage(text) {
        const alertMessage = document.createElement('div');
        alertMessage.classList.add(
            'fixed', 'top-4', 'right-4', 'bg-gradient-to-r', 
            'from-gray-800', 'to-gray-600', 'text-white', 
            'p-5', 'rounded-lg', 'shadow-xl', 'opacity-90', 
            'z-[10001]', 'transform', 'scale-90', 'transition-transform', 
            'border-2', 'border-indigo-500'
        );
        alertMessage.innerHTML = `<span class="font-semibold">ℹ︎</span> <span>${text}</span>`;
        document.body.appendChild(alertMessage);
        setTimeout(() => alertMessage.style.transform = 'translateX(0) scale(1)', 0);
        setTimeout(() => {
            alertMessage.style.opacity = '0';
            alertMessage.style.transform = 'translateX(100%) scale(1.1)';
            setTimeout(() => alertMessage.remove(), 1000);
        }, 3500);
    }
</script>
</body>
</html>
